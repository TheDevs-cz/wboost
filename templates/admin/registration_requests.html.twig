{% extends 'base.html.twig' %}

{% set active_menu_item = 'admin_registration_requests' %}

{% block title %}Žádosti o registraci{% endblock %}

{% block breadcrumb %}
    <ol class="breadcrumb m-0 pt-0">
        <li class="breadcrumb-item"><i class="uil-home-alt"></i> <a href="{{ path('homepage') }}">Projekty</a></li>
        <li class="breadcrumb-item">Administrace</li>
        <li class="breadcrumb-item active">{{ block('title') }}</li>
    </ol>
{% endblock %}

{% block content %}
    {% if requests|length == 0 %}
        <div class="alert alert-info">
            Zatím nejsou žádné žádosti o registraci.
        </div>
    {% else %}
        <div class="card shadow-sm rounded-3 overflow-hidden">
            <div class="card-body p-0">
                <div class="table-responsive rounded-3">
                    <table class="table table-hover table-striped mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-3">E-mail</th>
                                <th>Požádáno</th>
                                <th>Stav</th>
                                <th class="pe-3" style="width: 200px;"></th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for request in requests %}
                                <tr>
                                    <td class="ps-3 fw-medium">{{ request.email }}</td>
                                    <td>{{ request.createdAt|date('d.m.Y H:i') }}</td>
                                    <td>
                                        {% if request.status.value == 'pending' %}
                                            <span class="badge bg-warning">Čeká</span>
                                        {% elseif request.status.value == 'invited' %}
                                            <span class="badge bg-success">Pozván</span>
                                        {% else %}
                                            <span class="badge bg-secondary">Zamítnuto</span>
                                        {% endif %}
                                    </td>
                                    <td class="text-end pe-3">
                                        {% if request.status.value == 'pending' %}
                                            <div class="btn-group btn-group-sm">
                                                <a href="{{ path('admin_invite_user', {'email': request.email}) }}" class="btn btn-outline-primary">
                                                    <i class="mdi mdi-account-plus"></i> Pozvat
                                                </a>
                                                <a href="#"
                                                   class="btn btn-outline-danger"
                                                   data-modal-id="{{ request.id }}"
                                                   data-action="click->confirm-modal#showModal">
                                                    <i class="mdi mdi-close"></i> Zamítnout
                                                </a>
                                            </div>

                                            <twig:ConfirmModal
                                                id="{{ request.id }}"
                                                url="{{ path('admin_dismiss_registration_request', {'id': request.id}) }}"
                                                confirmationText="Opravdu chcete zamítnout tuto žádost o registraci?" />
                                        {% endif %}
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    {% endif %}
{% endblock %}
