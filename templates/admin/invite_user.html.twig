{% extends 'base.html.twig' %}

{% set active_menu_item = 'admin_users' %}

{% block title %}Pozvat uživatele{% endblock %}

{% block breadcrumb %}
    <ol class="breadcrumb m-0 pt-0">
        <li class="breadcrumb-item"><i class="uil-home-alt"></i> <a href="{{ path('homepage') }}">Projekty</a></li>
        <li class="breadcrumb-item">Administrace</li>
        <li class="breadcrumb-item"><a href="{{ path('admin_users') }}">Uživatelé</a></li>
        <li class="breadcrumb-item active">{{ block('title') }}</li>
    </ol>
{% endblock %}

{% block content %}
    <div class="row">
        <div class="col-lg-8 col-xl-6">
            <div class="card">
                <div class="card-body">
                    {{ form_start(form) }}
                    {{ form_row(form.email) }}
                    {{ form_row(form.name) }}
                    {{ form_row(form.role) }}

                    {% if form.projectIds|length > 0 %}
                        {{ form_row(form.projectIds) }}
                    {% else %}
                        <p class="text-muted">Zatím nejsou žádné projekty k předsdílení.</p>
                    {% endif %}

                    <div class="mt-3">
                        <button type="submit" class="btn btn-primary">Odeslat pozvánku</button>
                        <a href="{{ path('admin_users') }}" class="btn btn-outline-secondary">Zpět</a>
                    </div>
                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>
{% endblock %}
