{% extends 'base.html.twig' %}

{% set active_menu_item = 'template_groups' %}

{% block title %}Přidat rozměr do skupiny{% endblock %}

{% block breadcrumb %}
    <ol class="breadcrumb m-0 pt-0">
        <li class="breadcrumb-item"><i class="uil-home-alt"></i> <a href="{{ path('homepage') }}">Projekty</a></li>
        <li class="breadcrumb-item"><a href="{{ path('project_dashboard', {'id': project.id}) }}">{{ project.name }}</a></li>
        <li class="breadcrumb-item"><a href="{{ path('template_groups', {'projectId': project.id}) }}">Skupiny šablon</a></li>
        <li class="breadcrumb-item"><a href="{{ path('template_group_editor', {'groupId': group.id}) }}">{{ group.name }}</a></li>
        <li class="breadcrumb-item active">{{ block('title') }}</li>
    </ol>
{% endblock %}

{% block content %}
    <div class="card">
        <div class="card-body" data-controller="custom-template-dimension template-group-dimension">
            {{ form_start(form) }}

            {{ form_row(form.module, {'attr': {'data-action': 'change->template-group-dimension#toggleModule'}}) }}

            <div data-template-group-dimension-target="socialSection">
                {{ form_row(form.socialDimension) }}
            </div>

            <div data-template-group-dimension-target="customSection">
                <label class="form-label">Předvolby formátu:</label>
                <div class="mb-3">
                    {% for preset in [
                        {label: 'A5', width: 148, height: 210},
                        {label: 'A4', width: 210, height: 297},
                        {label: 'A3', width: 297, height: 420},
                    ] %}
                        <button
                            type="button"
                            class="btn btn-sm btn-outline-secondary rounded-pill me-1"
                            data-action="custom-template-dimension#applyPreset"
                            data-custom-template-dimension-unit-param="mm"
                            data-custom-template-dimension-width-param="{{ preset.width }}"
                            data-custom-template-dimension-height-param="{{ preset.height }}"
                        >{{ preset.label }} ({{ preset.width }}×{{ preset.height }} mm)</button>
                    {% endfor %}
                </div>

                <div class="row">
                    <div class="col-md-2">
                        {{ form_row(form.unit, { attr: { 'data-custom-template-dimension-target': 'unit' } }) }}
                    </div>
                    <div class="col-md-2">
                        {{ form_row(form.width, { attr: { 'data-custom-template-dimension-target': 'width' } }) }}
                    </div>
                    <div class="col-md-2">
                        {{ form_row(form.height, { attr: { 'data-custom-template-dimension-target': 'height' } }) }}
                    </div>
                </div>

                <p class="text-muted small">Fyzické jednotky (mm/cm) se na plátno převádí v tiskové kvalitě 300 DPI — např. A4 na výšku je 2480×3508 px.</p>
            </div>

            {{ form_row(form.backgroundImage) }}

            <p class="text-muted small">Nová varianta vznikne s prázdným plátnem — prvky do ní přenesete ve skupinovém editoru tlačítkem „Srovnat podle skupiny".</p>

            {{ form_rest(form) }}

            <button class="btn btn-primary" type="submit">Přidat</button>

            {{ form_end(form) }}
        </div>
    </div>
{% endblock %}
