{% extends 'base.html.twig' %}

{% set active_menu_item = 'template_groups' %}

{% block title %}Vytvořit skupinu z existující šablony{% endblock %}

{% block breadcrumb %}
    <ol class="breadcrumb m-0 pt-0">
        <li class="breadcrumb-item"><i class="uil-home-alt"></i> <a href="{{ path('homepage') }}">Projekty</a></li>
        <li class="breadcrumb-item"><a href="{{ path('project_dashboard', {'id': project.id}) }}">{{ project.name }}</a></li>
        <li class="breadcrumb-item"><a href="{{ path('template_groups', {'projectId': project.id}) }}">Skupiny šablon</a></li>
        <li class="breadcrumb-item active">{{ block('title') }}</li>
    </ol>
{% endblock %}

{% block content %}
    <div class="card">
        <div class="card-body py-2 d-flex align-items-center">
            <p class="text-muted my-1">Vyberte variantu, která poslouží jako výchozí design nové skupiny. Design se <strong>zkopíruje</strong> do všech rozměrů skupiny (poměrově přepočítaný) — původní šablona zůstane beze změny.</p>
            <a href="{{ path('add_template_group', {'projectId': project.id}) }}" class="btn btn-sm btn-outline-secondary rounded-pill ms-auto text-nowrap"><i class="mdi mdi-plus"></i> Raději začít od nuly</a>
        </div>
    </div>

    {% if social_templates|length == 0 and custom_templates|length == 0 %}
        <div class="card">
            <div class="card-body text-center text-muted py-5">
                <i class="uil-images" style="font-size: 2rem;"></i>
                <p class="mb-1 mt-2"><strong>V projektu zatím nejsou žádné šablony, ze kterých by šlo vyjít.</strong></p>
                <p class="mb-3">Vytvořte nejdřív šablonu pro sociální sítě nebo vlastní šablonu — nebo založte skupinu s prázdným plátnem.</p>
                <a href="{{ path('add_template_group', {'projectId': project.id}) }}" class="btn btn-outline-primary rounded-pill"><i class="mdi mdi-plus"></i> Nová skupina od nuly</a>
            </div>
        </div>
    {% endif %}

    {% if social_templates|length %}
        <h4 class="header-title mb-2 mt-1">Šablony pro sociální sítě</h4>

        {% for template in social_templates %}
            <div class="card">
                <div class="card-body py-2">
                    <p class="fw-bold mb-2 mt-1">
                        {{ template.name }}
                        {% if template.category %}<span class="badge bg-secondary-lighten text-secondary ms-1">{{ template.category.name }}</span>{% endif %}
                        {% if template.group %}<span class="badge bg-info-lighten text-info ms-1"><i class="uil-layer-group"></i> Skupina: {{ template.group.name }}</span>{% endif %}
                    </p>
                    <div class="d-flex flex-wrap gap-2">
                        {% for variant in template.variants %}
                            <a href="{{ path('add_template_group', {'projectId': project.id, 'sourceModule': 'social', 'sourceVariantId': variant.id}) }}"
                               class="template-source-tile text-center text-body"
                               title="Použít tento design jako výchozí">
                                <span class="template-source-thumb d-block rounded"
                                      style="aspect-ratio: {{ variant.dimension.width }} / {{ variant.dimension.height }}; background: url('{{ uploaded_asset(variant.previewImagePath ?: variant.backgroundImage) }}') center center no-repeat; background-size: cover;"></span>
                                <span class="font-11 text-muted d-block mt-1">{{ variant.dimension.value }}</span>
                                <span class="template-source-cta font-11 d-block">Použít <i class="mdi mdi-arrow-right"></i></span>
                            </a>
                        {% endfor %}
                    </div>
                </div>
            </div>
        {% endfor %}
    {% endif %}

    {% if custom_templates|length %}
        <h4 class="header-title mb-2 mt-1">Šablony (vlastní rozměry)</h4>

        {% for template in custom_templates %}
            <div class="card">
                <div class="card-body py-2">
                    <p class="fw-bold mb-2 mt-1">
                        {{ template.name }}
                        {% if template.category %}<span class="badge bg-secondary-lighten text-secondary ms-1">{{ template.category.name }}</span>{% endif %}
                        {% if template.group %}<span class="badge bg-info-lighten text-info ms-1"><i class="uil-layer-group"></i> Skupina: {{ template.group.name }}</span>{% endif %}
                    </p>
                    <div class="d-flex flex-wrap gap-2">
                        {% for variant in template.variants %}
                            <a href="{{ path('add_template_group', {'projectId': project.id, 'sourceModule': 'custom', 'sourceVariantId': variant.id}) }}"
                               class="template-source-tile text-center text-body"
                               title="Použít tento design jako výchozí">
                                <span class="template-source-thumb d-block rounded"
                                      style="aspect-ratio: {{ variant.dimension.width }} / {{ variant.dimension.height }}; background: url('{{ uploaded_asset(variant.previewImagePath ?: variant.backgroundImage) }}') center center no-repeat; background-size: cover;"></span>
                                <span class="font-11 text-muted d-block mt-1">{{ variant.dimension.label }}</span>
                                <span class="template-source-cta font-11 d-block">Použít <i class="mdi mdi-arrow-right"></i></span>
                            </a>
                        {% endfor %}
                    </div>
                </div>
            </div>
        {% endfor %}
    {% endif %}
{% endblock %}
