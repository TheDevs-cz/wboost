{#
    Stage 5 (post-hotfix): server-rendered user-fill page for a SocialNetworkTemplateVariant.

    Architecture:
    - Inputs use data-model="on(change)|textValues[<uuid>]" so LiveProp state
      updates on field blur. That re-render refreshes the preview <img>.
    - The same inputs ALSO carry a `name` attribute and live inside a regular
      <form> that POSTs to the download route. Export is a plain form submit,
      not a LiveAction — Live Component's RedirectResponse path goes through
      Turbo.visit, which doesn't reliably hand binary responses back to the
      browser as a download. data-turbo="false" plus a normal form submit
      sidesteps that entirely.
    - No session stashing: the form data IS the input state.
#}
<div {{ attributes }}>
    <div class="row">
        <div class="col-2">
            <form
                method="POST"
                action="{{ path('social_network_template_variant_download', { variantId: variant.id }) }}"
                data-turbo="false"
            >
                {% if variant.inputs %}
                    <div class="card mb-2">
                        <div class="card-body">
                            {% for input in variant.inputs %}
                                {% if not input.locked %}
                                    <div class="mb-2">
                                        <label class="form-label small" for="text-input-{{ loop.index0 }}">
                                            {{ input.name }}
                                            {% if input.description %}
                                                <br><small class="text-muted">{{ input.description }}</small>
                                            {% endif %}
                                        </label>
                                        <input
                                            type="text"
                                            class="form-control form-control-sm"
                                            id="text-input-{{ loop.index0 }}"
                                            name="textValues[{{ input.inputId }}]"
                                            data-model="on(change)|textValues[{{ input.inputId }}]"
                                            {% if input.maxLength %}maxlength="{{ input.maxLength }}"{% endif %}
                                            value="{{ this.textValues[input.inputId] ?? '' }}"
                                        >
                                    </div>
                                {% endif %}
                                {% if input.hidable %}
                                    <div class="mb-2 form-check">
                                        <input
                                            type="checkbox"
                                            id="hide-control-{{ loop.index0 }}"
                                            class="form-check-input"
                                            name="hiddenValues[{{ input.inputId }}]"
                                            value="1"
                                            data-model="on(change)|hiddenValues[{{ input.inputId }}]"
                                            {% if this.hiddenValues[input.inputId] ?? false %}checked{% endif %}
                                        >
                                        <label for="hide-control-{{ loop.index0 }}" class="form-check-label small">Schovat</label>
                                    </div>
                                {% endif %}
                            {% endfor %}
                        </div>
                    </div>
                {% endif %}

                <button type="submit" class="btn btn-primary me-1 mb-1">
                    Export do PNG
                </button>
            </form>
        </div>

        <div class="col-10">
            <div class="canvas-wrapper">
                {% set preview = this.previewDataUri() %}
                {% if preview %}
                    <img src="{{ preview }}" alt="" style="max-width: 100%; height: auto;">
                {% else %}
                    <p class="text-muted">Náhled se generuje…</p>
                {% endif %}
            </div>
        </div>
    </div>
</div>
