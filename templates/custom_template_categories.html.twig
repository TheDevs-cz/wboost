{% extends 'base.html.twig' %}

{% set active_menu_item = 'custom_templates' %}

{% block title %}Kategorie šablon{% endblock %}

{% block breadcrumb %}
    <ol class="breadcrumb m-0 pt-0">
        <li class="breadcrumb-item"><i class="uil-home-alt"></i> <a href="{{ path('homepage') }}">Projekty</a></li>
        <li class="breadcrumb-item"><a href="{{ path('project_dashboard', {'id': project.id}) }}">{{ project.name }}</a></li>
        <li class="breadcrumb-item"><a href="{{ path('custom_templates', {'projectId': project.id}) }}">Šablony</a></li>
        <li class="breadcrumb-item active">{{ block('title') }}</li>
    </ol>
{% endblock %}

{% block content %}

    <div class="row mb-2">
        <div class="col-sm-12">
            <a href="{{ path('add_custom_template_category', {'id': project.id}) }}" class="btn btn-outline-primary rounded-pill mb-3"><i class="mdi mdi-plus"></i> Nová kategorie</a>
        </div>
    </div>

    <div class="row"
         data-controller="dragula"
         data-dragula-sort-url-value="{{ path('sort_custom_template_categories', {'projectId': project.id}) }}"
         data-dragula-direction-value="horizontal"
         data-dragula-target="container"
    >
        {% for category in categories %}
            <div class="col-sm-3">
                <div class="card">
                    <div class="card-body d-flex align-items-center gap-2" data-entity-id="{{ category.id }}">
                        <h4 class="my-0 flex-grow-1" style="min-width: 0; overflow-wrap: anywhere;">{{ category.name }}</h4>
                        <div class="d-flex align-items-center gap-1 flex-shrink-0">
                            <a href="{{ path('edit_custom_template_category', {'categoryId': category.id}) }}" class="btn btn-outline-secondary btn-sm px-1 py-0"><i class="mdi mdi-pencil"></i></a>
                            <a href="#"
                               class="btn btn-outline-danger btn-sm px-1 py-0"
                               data-modal-id="{{ category.id }}"
                               data-action="click->confirm-modal#showModal"><i class="mdi mdi-delete"></i></a>
                            <span class="dragula-handle text-lighter ms-1"></span>
                        </div>

                        <twig:ConfirmModal
                            id="{{ category.id }}"
                            url="{{ path('delete_custom_template_category', {'categoryId': category.id}) }}"
                            confirmationText="Opravdu chcete smazat tuto kategorii? Šablony v této kategorii nebudou smazány a zůstanou zachovány bez kategorie." />
                    </div>
                </div>
            </div>
        {% endfor %}
    </div>
{% endblock %}
