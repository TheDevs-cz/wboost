{% extends 'base.html.twig' %}

{% block title %}Můj účet{% endblock %}

{% block breadcrumb %}
    <ol class="breadcrumb m-0 pt-0">
        <li class="breadcrumb-item"><i class="uil-home-alt"></i> <a href="{{ path('homepage') }}">Projekty</a></li>
        <li class="breadcrumb-item active">{{ block('title') }}</li>
    </ol>
{% endblock %}

{% block content %}
    <div class="row">
        <div class="col-sm-12">
            <!-- Profile -->
            <div class="card bg-primary">
                <div class="card-body profile-user-box">
                    <div class="row">
                        <div class="col-sm-8">
                            <div class="row align-items-center">
                                <div class="col-auto">
                                    <div class="avatar-md">
                                        <img src="{{ asset('theme/images/users/avatar-2.jpg') }}" alt="" class="rounded-circle img-thumbnail">
                                    </div>
                                </div>
                                <div class="col">
                                    <div>
                                        <h4 class="mt-1 mb-1 text-white">{{ app.user.displayName }}</h4>
                                    </div>
                                </div>
                            </div>
                        </div> <!-- end col-->

                        <div class="col-sm-4">
                            <div class="text-center mt-sm-0 mt-3 text-sm-end">
                                <a href="{{ path('change_password') }}" type="button" class="btn btn-light me-1">
                                    <i class="mdi mdi-key me-1"></i> Změnit heslo
                                </a>
                                <a href="{{ path('edit_profile') }}" type="button" class="btn btn-light">
                                    <i class="mdi mdi-account-edit me-1"></i> Upravit profil
                                </a>
                            </div>
                        </div> <!-- end col-->
                    </div> <!-- end row -->

                </div> <!-- end card-body/ profile-user-box-->
            </div><!--end profile/ card -->
        </div> <!-- end col-->
    </div>

    <div class="card">
        <div class="card-body">
            <div class="text-start">
                <p class="text-muted"><strong>E-mail:</strong> <span class="ms-2">{{ app.user.email }}</span></p>
                <p class="text-muted"><strong>Jméno:</strong> <span class="ms-2">{{ app.user.name ?: '-' }}</span></p>
                <p class="text-muted"><strong>Registrován:</strong> <span class="ms-2">{{ app.user.registeredAt|date('H:i d.m.Y') }}</span></p>
            </div>
        </div>
    </div>

    <div class="card">
        <div class="card-body">
            <h4 class="header-title mb-3">Propojené účty</h4>

            {% if facebookAccount %}
                {% if facebookAccount.needsReconnect %}
                    <div class="alert alert-warning">
                        Připojení k Facebooku vypršelo nebo bylo odvoláno — pro publikování je potřeba účet znovu propojit.
                    </div>
                {% endif %}

                <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
                    <div>
                        <i class="mdi mdi-facebook text-primary me-1 font-18 align-middle"></i>
                        <strong>Facebook</strong>
                        <span class="text-muted ms-2">{{ facebookAccount.displayName ?: 'propojeno' }}</span>
                        <span class="text-muted ms-2 small">od {{ facebookAccount.connectedAt|date('d.m.Y') }}</span>
                    </div>
                    <div>
                        {% if facebookAccount.needsReconnect %}
                            <a href="{{ path('oauth_facebook_connect') }}" class="btn btn-sm btn-primary me-1">
                                <i class="mdi mdi-refresh me-1"></i>Znovu propojit
                            </a>
                        {% else %}
                            <a href="{{ path('oauth_facebook_connect') }}" class="btn btn-sm btn-outline-primary me-1" title="Obnovit oprávnění a token">
                                <i class="mdi mdi-refresh me-1"></i>Obnovit propojení
                            </a>
                        {% endif %}
                        <a href="{{ path('facebook_disconnect') }}" class="btn btn-sm btn-outline-danger">
                            <i class="mdi mdi-link-off me-1"></i>Odpojit
                        </a>
                    </div>
                </div>
                <p class="text-muted small mt-2 mb-0">
                    Přes propojený facebookový účet lze publikovat šablony na vaše facebookové stránky
                    a instagramové profesionální účty (propojené se stránkou).
                </p>
            {% else %}
                <p class="text-muted">
                    Propojte svůj facebookový účet a publikujte vyplněné šablony přímo na facebookové
                    stránky a Instagram — bez stahování PNG.
                </p>
                <a href="{{ path('oauth_facebook_connect') }}" class="btn btn-primary">
                    <i class="mdi mdi-facebook me-1"></i> Propojit Facebook
                </a>
            {% endif %}
        </div>
    </div>

{% endblock %}
