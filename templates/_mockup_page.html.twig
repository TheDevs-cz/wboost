{# Renders a mockup page as the canonical CSS grid (3 columns × 2 rows, uniform
   gap, fixed page aspect ratio). The same geometry drives the admin layout
   picker and the interactive uploader, so admin preview and manual render
   always match. Params: mockup_page (required), show_placeholders (optional,
   renders a placeholder in empty slots — admin surfaces only). #}
<div class="mockup-grid-container">
    <div class="mockup-grid">
        {% for slot in mockup_page.layout.slots %}
            <div class="mockup-slot"
                 style="grid-column: {{ slot.column }} / span {{ slot.columnSpan }}; grid-row: {{ slot.row }} / span {{ slot.rowSpan }};">
                {% if mockup_page.images[loop.index0] ?? null %}
                    <img src="{{ uploaded_asset(mockup_page.images[loop.index0]) }}" alt="{{ mockup_page.name }} – obrázek {{ loop.index }}" loading="lazy">
                {% elseif show_placeholders|default(false) %}
                    <div class="mockup-slot-placeholder">
                        <i class="ri-image-line"></i>
                    </div>
                {% endif %}
            </div>
        {% endfor %}
    </div>
</div>
