{% extends 'base.html.twig' %}

{% set active_menu_item = 'weekly_menus' %}

{% block title %}Jídelníčky{% endblock %}

{% block breadcrumb %}
    <ol class="breadcrumb m-0 pt-0">
        <li class="breadcrumb-item"><i class="uil-home-alt"></i> <a href="{{ path('homepage') }}">Projekty</a></li>
        <li class="breadcrumb-item"><a href="{{ path('project_dashboard', {'id': project.id}) }}">{{ project.name }}</a></li>
        <li class="breadcrumb-item active">{{ block('title') }}</li>
    </ol>
{% endblock %}

{% block content %}
    <div class="row mb-2">
        <div class="col-sm-12">
            {% if is_granted('project_edit', project) %}
                <a href="{{ path('add_weekly_menu', {'projectId': project.id}) }}" class="btn btn-outline-primary rounded-pill mb-3">
                    <i class="mdi mdi-plus"></i> Nový jídelníček
                </a>
            {% endif %}
            <a href="{{ path('meals', {'projectId': project.id}) }}" class="btn btn-outline-secondary rounded-pill mb-3">
                <i class="mdi mdi-food"></i> Seznam jídel
            </a>
            <a href="{{ path('diets', {'projectId': project.id}) }}" class="btn btn-outline-secondary rounded-pill mb-3">
                <i class="mdi mdi-account-heart"></i> Diety
            </a>
            <a href="{{ path('dish_types', {'projectId': project.id}) }}" class="btn btn-outline-secondary rounded-pill mb-3">
                <i class="mdi mdi-food-variant"></i> Druhy jídel
            </a>
        </div>
    </div>

    {% if menus|length == 0 %}
        <div class="alert alert-info">
            Zatím nebyl vytvořen žádný jídelníček.
        </div>
    {% else %}
        <div class="row">
            {% for menu in menus %}
                <div class="col-md-4 col-lg-3 mb-4">
                    <div class="card h-100">
                        <div class="card-body">
                            <h5 class="card-title">{{ menu.name }}</h5>
                            <p class="card-text text-muted">
                                {{ menu.validFrom|date('d.m.Y') }} - {{ menu.validTo|date('d.m.Y') }}
                            </p>
                            {% if menu.approvalEmail is not null %}
                                <div class="mb-2">
                                    <span class="badge {{ menu.approvalStatus.badgeClass }}">{{ menu.approvalStatus.label }}</span>
                                    {% if menu.approvalStatus.value == 'approved' and menu.approvalRespondedAt %}
                                        <br><small class="text-muted">{{ menu.approvalEmail }} &middot; {{ menu.approvalRespondedAt|date('d.m.Y H:i') }}</small>
                                    {% elseif menu.approvalStatus.value == 'denied' and menu.approvalRespondedAt %}
                                        <br><small class="text-muted">{{ menu.approvalEmail }} &middot; {{ menu.approvalRespondedAt|date('d.m.Y H:i') }}</small>
                                    {% endif %}
                                    {% if menu.approvalComment is not empty %}
                                        <br><small class="text-muted fst-italic">&bdquo;{{ menu.approvalComment }}&ldquo;</small>
                                    {% endif %}
                                </div>
                            {% endif %}
                            <p class="card-text small text-muted mb-0">
                                Vytvořeno: {{ menu.createdAt|date('d.m.Y H:i') }}
                                {% if menu.updatedAt %}
                                    <br>Upraveno: {{ menu.updatedAt|date('d.m.Y H:i') }}
                                {% endif %}
                            </p>
                        </div>
                        <div class="card-footer bg-transparent border-top-0 d-flex justify-content-between align-items-center">
                            <a href="{{ path('weekly_menu_planner', {'menuId': menu.id}) }}" class="btn btn-sm btn-success">
                                <i class="mdi mdi-calendar-edit"></i> Sestavit
                            </a>
                            <div class="dropdown">
                                <a href="#" class="dropdown-toggle arrow-none btn btn-sm btn-outline-secondary" data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="mdi mdi-dots-vertical"></i>
                                </a>
                                <div class="dropdown-menu dropdown-menu-end">
                                    <a href="{{ path('edit_weekly_menu', {'menuId': menu.id}) }}" class="dropdown-item">
                                        <i class="mdi mdi-pencil me-1"></i> Upravit
                                    </a>
                                    <a href="{{ path('download_weekly_menu_pdf', {'menuId': menu.id}) }}" class="dropdown-item">
                                        <i class="mdi mdi-file-pdf-box me-1"></i> Stáhnout PDF
                                    </a>
                                    <a href="{{ path('public_weekly_menu', {'menuId': menu.id}) }}" class="dropdown-item" target="_blank">
                                        <i class="mdi mdi-share-variant me-1"></i> Veřejný odkaz
                                    </a>
                                    {% if is_granted('project_edit', project) and menu.approvalEmail is not null and menu.approvalStatus.value in ['not_requested', 'denied'] %}
                                        <div class="dropdown-divider"></div>
                                        <form action="{{ path('request_weekly_menu_approval', {'menuId': menu.id}) }}" method="post">
                                            <button type="submit" class="dropdown-item" onclick="return confirm('Odeslat žádost o schválení na {{ menu.approvalEmail }}?');">
                                                <i class="mdi mdi-email-check me-1"></i> Požádat o schválení
                                            </button>
                                        </form>
                                    {% endif %}
                                    {% if is_granted('project_edit', project) %}
                                        <form action="{{ path('duplicate_weekly_menu', {'menuId': menu.id}) }}" method="post">
                                            <button type="submit" class="dropdown-item">
                                                <i class="mdi mdi-content-copy me-1"></i> Duplikovat
                                            </button>
                                        </form>
                                        <div class="dropdown-divider"></div>
                                        <form action="{{ path('delete_weekly_menu', {'menuId': menu.id}) }}" method="post" onsubmit="return confirm('Opravdu chcete smazat tento jídelníček?');">
                                            <button type="submit" class="dropdown-item text-danger">
                                                <i class="mdi mdi-delete me-1"></i> Smazat
                                            </button>
                                        </form>
                                    {% endif %}
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% endif %}
{% endblock %}
