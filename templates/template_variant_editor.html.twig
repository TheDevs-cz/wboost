{#
    Shared admin canvas editor for template variants — rendered by BOTH the
    social-network module and the custom-template (Šablony) module, so editor changes land
    in each automatically. The rendering controller supplies the module-specific
    pieces:

      menu_item             active left-nav key ('social_networks' / 'custom_templates')
      module_label          breadcrumb label ('Sociální sítě' / 'Šablony')
      module_templates_url  URL of the module's template list
      module_variants_url   URL of the template's variant list
      edit_variant_url      POST target for background changes
      export_url            the user-fill page URL
      dimension_label       human label of the variant's dimension

    plus the editor data itself: project, template, variant, fonts, editor_form,
    font_faces, gallery_directories. The variant only needs `canvas`,
    `backgroundImage` and `dimension.width/height` (pixels).

    The stage / left panel / fonts / scripts / modals markup is shared with the
    template-group editor via the templates/editor/_editor_*.html.twig partials.
#}
{% extends 'base.html.twig' %}

{% set active_menu_item = menu_item %}

{% block title %}Editor - Varianta {{ dimension_label }}{% endblock %}

{% block breadcrumb %}
    <ol class="breadcrumb m-0 pt-0">
        <li class="breadcrumb-item"><i class="uil-home-alt"></i> <a href="{{ path('homepage') }}">Projekty</a></li>
        <li class="breadcrumb-item"><a href="{{ path('project_dashboard', {'id': project.id}) }}">{{ project.name }}</a></li>
        <li class="breadcrumb-item"><a href="{{ module_templates_url }}">{{ module_label }}</a></li>
        <li class="breadcrumb-item"><a href="{{ module_variants_url }}">{{ template.name }}</a></li>
        <li class="breadcrumb-item active">{{ block('title') }}</li>
    </ol>
{% endblock %}

{% block content %}
    {{ include('editor/_editor_scripts.html.twig') }}
    {{ include('editor/_editor_fonts.html.twig') }}

    <div
        id="canvas-container"
        data-controller="canvas-editor canvas-history canvas-clipboard canvas-zoom canvas-text-toolbar canvas-input-properties canvas-image-properties canvas-alignment canvas-floating-toolbar canvas-container canvas-layers canvas-snapping canvas-rulers"
        data-canvas-editor-background-image-value="{{ uploaded_asset(variant.backgroundImage) }}"
        data-canvas-editor-custom-fonts-value='{{ font_faces|json_encode }}'
        data-canvas-editor-canvas-json="{{ variant.canvas }}"
        data-canvas-editor-edit-variant-url-value="{{ edit_variant_url }}"
        data-canvas-history-canvas-editor-outlet="#canvas-container"
        data-canvas-clipboard-canvas-editor-outlet="#canvas-container"
        data-canvas-text-toolbar-canvas-editor-outlet="#canvas-container"
        data-canvas-input-properties-canvas-editor-outlet="#canvas-container"
        data-canvas-image-properties-canvas-editor-outlet="#canvas-container"
        data-canvas-alignment-canvas-editor-outlet="#canvas-container"
        data-canvas-floating-toolbar-canvas-editor-outlet="#canvas-container"
        data-canvas-container-canvas-editor-outlet="#canvas-container"
        data-canvas-layers-canvas-editor-outlet="#canvas-container"
        data-canvas-layers-canvas-floating-toolbar-outlet="#canvas-container"
        data-canvas-snapping-canvas-editor-outlet="#canvas-container"
        data-canvas-rulers-canvas-editor-outlet="#canvas-container"
        data-action="
            canvas-editor:selection:changed->canvas-clipboard#onSelectionChanged
            canvas-editor:selection:changed->canvas-text-toolbar#updateFromSelection
            canvas-editor:selection:changed->canvas-input-properties#updateFromSelection
            canvas-editor:selection:changed->canvas-image-properties#updateFromSelection
            canvas-editor:selection:changed->canvas-alignment#onSelectionChanged
            canvas-editor:selection:changed->canvas-floating-toolbar#onSelectionChanged
            canvas-editor:selection:changed->canvas-container#onSelectionChanged
            canvas-editor:selection:changed->canvas-layers#onSelectionChanged
            canvas-editor:canvas:loaded->canvas-container#onCanvasLoaded
            canvas-editor:canvas:loaded->canvas-history#onCanvasLoaded
            canvas-editor:canvas:loaded->canvas-layers#onCanvasLoaded
            canvas-editor:dirty->canvas-layers#onCanvasDirty
            canvas-zoom:changed->canvas-layers#unhover
            canvas-zoom:changed->canvas-floating-toolbar#reposition
            canvas-zoom:changed->canvas-container#repositionZones
            canvas-zoom:changed->canvas-rulers#refresh
            canvas-editor:canvas:loaded->canvas-rulers#onCanvasLoaded
            canvas-editor:copy->canvas-clipboard#copy
            canvas-editor:paste->canvas-clipboard#paste
            asset-selected@window->canvas-editor#onAssetSelected
        "
    >
        {{ form_start(editor_form) }}

        <div class="card mb-2" data-editor-header style="position: sticky;top: 0px;z-index: 1000;">
            <div class="card-body p-2">
                <div class="mb-1">
                    <button class="btn btn-sm btn-outline-secondary me-3" data-action="canvas-editor#showBackgroundModal" type="button"><i class="mdi mdi-image"></i> Pozadí</button>

                    <button class="btn btn-sm btn-outline-secondary me-1 disabled" type="button" data-canvas-history-target="undoButton" data-action="canvas-history#undo"><i class="mdi mdi-undo-variant"></i></button>
                    <button class="btn btn-sm btn-outline-secondary me-3 disabled" type="button" data-canvas-history-target="redoButton" data-action="canvas-history#redo"><i class="mdi mdi-redo-variant"></i></button>

                    <button class="btn btn-sm btn-outline-secondary me-1 disabled" type="button" data-action="canvas-zoom#zoomOut" data-canvas-zoom-target="zoomOutButton"><i class="ri-zoom-out-line"></i></button>
                    <button class="btn btn-sm btn-outline-secondary me-1 disabled" type="button" data-action="canvas-zoom#zoomIn" data-canvas-zoom-target="zoomInButton"><i class="ri-zoom-in-line"></i></button>

                    <p class="d-inline-block my-0 small text-muted" data-canvas-zoom-target="scaleDisplay">100%</p>

                    {% if variant.group and is_granted('ROLE_DESIGNER') %}
                        <a href="{{ path('template_group_editor', {'groupId': variant.group.id}) }}" class="badge bg-info-lighten text-info ms-2" title="Tato varianta vznikla ve skupině — otevřít skupinový editor"><i class="uil-layer-group"></i> Skupina: {{ variant.group.name }}</a>
                    {% endif %}

                    <div class="d-inline-block float-end">
                        <p data-canvas-editor-target="unsavedChangesMessage" class="d-inline-block d-none my-0 me-2 small fw-bold text-danger">Neuložené změny</p>

                        <button class="btn btn-sm btn-primary me-1" type="button" data-action="canvas-editor#submitForm">Uložit</button>

                        <a href="{{ export_url }}" class="btn btn-sm btn-outline-secondary me-1" data-action="canvas-editor#confirmExport">Export</a>
                    </div>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-12 col-lg-2">
                {{ include('editor/_editor_left_panel.html.twig') }}
            </div>

            <div class="col-12 col-lg-10">
                {{ include('editor/_editor_stage.html.twig', {
                    'canvas_width': variant.dimension.width,
                    'canvas_height': variant.dimension.height,
                }) }}

                {{ form_widget(editor_form.canvas, { attr: { 'data-canvas-editor-target': 'canvas' } }) }}
                {{ form_widget(editor_form.textInputs, { attr: { 'data-canvas-editor-target': 'textInputs' } }) }}
                {{ form_widget(editor_form.imageInputs, { attr: { 'data-canvas-editor-target': 'imageInputs' } }) }}
                {{ form_widget(editor_form.imagePreview, { attr: { 'data-canvas-editor-target': 'previewImage' } }) }}
            </div>
        </div>

        {{ form_end(editor_form) }}

        {{ include('editor/_editor_modals.html.twig') }}

        {# Shown when Export is clicked with unsaved canvas changes. The export
           renders from the last saved variant, so we let the user save first. #}
        <div class="modal fade" id="exportUnsavedModal" tabindex="-1" aria-labelledby="exportUnsavedModalLabel" aria-hidden="true">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title" id="exportUnsavedModalLabel">Neuložené změny</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <p class="mb-0">Máte neuložené změny. Export se vytvoří z naposledy uložené verze, takže vaše poslední úpravy se v něm neprojeví. Chcete změny nejdříve uložit?</p>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Zrušit</button>
                        <button type="button" class="btn btn-outline-danger" data-action="canvas-editor#exportWithoutSaving">Pokračovat bez uložení</button>
                        <button type="button" class="btn btn-primary" data-action="canvas-editor#saveAndExport">Uložit a exportovat</button>
                    </div>
                </div>
            </div>
        </div>

    </div>
{% endblock %}
