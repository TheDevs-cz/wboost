{% extends 'base.html.twig' %}

{% set active_menu_item = 'weekly_menus' %}

{% block title %}Upravit jídelníček{% endblock %}

{% block breadcrumb %}
    <ol class="breadcrumb m-0 pt-0">
        <li class="breadcrumb-item"><i class="uil-home-alt"></i> <a href="{{ path('homepage') }}">Projekty</a></li>
        <li class="breadcrumb-item"><a href="{{ path('project_dashboard', {'id': project.id}) }}">{{ project.name }}</a></li>
        <li class="breadcrumb-item"><a href="{{ path('weekly_menus', {'projectId': project.id}) }}">Jídelníčky</a></li>
        <li class="breadcrumb-item active">{{ block('title') }}</li>
    </ol>
{% endblock %}

{% block content %}
    <div class="card">
        <div class="card-body">
            {{ form_start(form) }}
            {{ form_row(form.name) }}
            <div class="row">
                <div class="col-md-6">
                    <div class="mb-3" data-controller="flatpickr-range">
                        <label class="form-label">Platnost</label>
                        <input type="text"
                               class="form-control"
                               placeholder="Vyberte období"
                               data-input>
                        {{ form_widget(form.validFrom, {attr: {class: 'd-none', 'data-flatpickr-range-target': 'from'}}) }}
                        {{ form_widget(form.validTo, {attr: {class: 'd-none', 'data-flatpickr-range-target': 'to'}}) }}
                    </div>
                </div>
            </div>
            <div class="row">
                <div class="col-md-6">
                    {{ form_row(form.createdBy) }}
                </div>
                <div class="col-md-6">
                    {{ form_row(form.approvedBy) }}
                </div>
            </div>

            <div class="row">
                <div class="col-md-6">
                    {{ form_row(form.approvalEmail) }}
                </div>
                <div class="col-md-6 d-flex align-items-end pb-3">
                    {% if menu.approvalEmail is not null %}
                        <span class="badge {{ menu.approvalStatus.badgeClass }} me-2">{{ menu.approvalStatus.label }}</span>
                        {% if menu.approvalRespondedAt %}
                            <small class="text-muted">{{ menu.approvalRespondedAt|date('d.m.Y H:i') }}</small>
                        {% endif %}
                    {% endif %}
                </div>
            </div>

            <input type="submit" name="submit" value="Uložit" class="btn btn-primary">
            <a href="{{ path('weekly_menus', {'projectId': project.id}) }}" class="btn btn-outline-secondary">Zrušit</a>
            <a href="{{ path('weekly_menu_planner', {'menuId': menu.id}) }}" class="btn btn-outline-success">
                <i class="mdi mdi-calendar-edit"></i> Sestavit menu
            </a>
            <a href="{{ path('download_weekly_menu_pdf', {'menuId': menu.id}) }}" class="btn btn-outline-secondary">
                <i class="mdi mdi-file-pdf-box"></i> Stáhnout PDF
            </a>

            {{ form_end(form) }}
        </div>
    </div>

    {% if menu.approvalEmail is not null %}
        <div class="card mt-3">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="card-title mb-0">Schvalovací proces</h5>
                    {% if menu.approvalStatus.value in ['not_requested', 'denied'] %}
                        <form action="{{ path('request_weekly_menu_approval', {'menuId': menu.id}) }}" method="post" class="d-inline">
                            <button type="submit" class="btn btn-sm btn-outline-primary" onclick="return confirm('Odeslat žádost o schválení na {{ menu.approvalEmail }}?');">
                                <i class="mdi mdi-email-check me-1"></i> Požádat o schválení
                            </button>
                        </form>
                    {% endif %}
                </div>

                {% if menu.approvalComment is not empty %}
                    <div class="alert alert-{{ menu.approvalStatus.value == 'approved' ? 'success' : 'danger' }} py-2 mb-3">
                        <small><strong>Komentář schvalovatele:</strong> {{ menu.approvalComment }}</small>
                    </div>
                {% endif %}

                {% if auditLogs|length > 0 %}
                    <table class="table table-sm table-bordered mb-0">
                        <thead class="table-light">
                            <tr>
                                <th style="width: 160px;">Datum</th>
                                <th>Událost</th>
                                <th style="width: 200px;">Provedl</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for log in auditLogs %}
                                <tr>
                                    <td><small>{{ log.createdAt|date('d.m.Y H:i') }}</small></td>
                                    <td><small>{{ log.event }}</small></td>
                                    <td><small>{{ log.performedBy ?? '–' }}</small></td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                {% else %}
                    <p class="text-muted small mb-0">Zatím žádná historie schvalování.</p>
                {% endif %}
            </div>
        </div>
    {% endif %}
{% endblock %}
