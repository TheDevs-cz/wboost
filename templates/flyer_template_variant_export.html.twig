{% extends 'base.html.twig' %}

{% block title %}Export - Varianta {{ variant.dimension.label }} ({{ variant.dimension.width }}x{{ variant.dimension.height }}px){% endblock %}
{% set active_menu_item = 'flyers' %}

{% block title_actions %}
    {% if is_granted('flyer_variant_edit', variant) %}
        <div class="text-sm-end mb-3">
            <a href="{{ path('flyer_template_variant_editor', {'variantId': variant.id}) }}" class="btn btn-primary"><i class="mdi mdi-pencil"></i> Zpět na editor</a>
        </div>
    {% endif %}
{% endblock %}

{% block breadcrumb %}
    <ol class="breadcrumb m-0 pt-0">
        <li class="breadcrumb-item"><i class="uil-home-alt"></i> <a href="{{ path('homepage') }}">Projekty</a></li>
        <li class="breadcrumb-item"><a href="{{ path('project_dashboard', {'id': project.id}) }}">{{ project.name }}</a></li>
        <li class="breadcrumb-item"><a href="{{ path('flyer_templates', {'projectId': project.id}) }}">Šablony</a></li>
        <li class="breadcrumb-item"><a href="{{ path('flyer_template_variants', {'templateId': template.id}) }}">{{ template.name }}</a></li>
        <li class="breadcrumb-item active">{{ block('title') }}</li>
    </ol>
{% endblock %}

{% block content %}
    {# The fill UI is driven by a Live Component; it renders its own preview
       server-side (Gotenberg PNG → base64 data URI). #}
    <twig:Flyer:VariantFiller :variant="variant" />
{% endblock %}
