{% extends 'base.html.twig' %}

{% set active_menu_item = 'template_groups' %}

{% block title %}Vyplnit a exportovat{% endblock %}

{% block breadcrumb %}
    <ol class="breadcrumb m-0 pt-0">
        <li class="breadcrumb-item"><i class="uil-home-alt"></i> <a href="{{ path('homepage') }}">Projekty</a></li>
        <li class="breadcrumb-item"><a href="{{ path('project_dashboard', {'id': project.id}) }}">{{ project.name }}</a></li>
        <li class="breadcrumb-item"><a href="{{ path('template_groups', {'projectId': project.id}) }}">Skupiny šablon</a></li>
        <li class="breadcrumb-item active">{{ group.name }}</li>
    </ol>
{% endblock %}

{% block content %}
    {% if variants|length == 0 %}
        <div class="card">
            <div class="card-body text-center text-muted py-5">
                <i class="uil-layer-group" style="font-size: 2rem;"></i>
                <p class="mb-1 mt-2"><strong>Skupina zatím nemá žádné varianty.</strong></p>
                <p class="mb-0">Nejdřív <a href="{{ path('add_template_group_dimension', {'groupId': group.id}) }}">přidejte rozměr</a>, potom tu půjde vše najednou vyplnit a stáhnout.</p>
            </div>
        </div>
    {% else %}
        <form method="post" action="{{ export_url }}" data-turbo="false"
              data-controller="group-fill"
              data-group-fill-debounce-value="900"
              data-group-fill-slots-value="{{ placement_slots|json_encode }}"
              data-group-fill-variants-value="{{ placement_variants|json_encode }}"
              data-action="keydown->group-fill#blockEnter submit->group-fill#exportStarted">

            <div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-3">
                <div>
                    <h3 class="my-0">{{ group.name }}</h3>
                    <p class="text-muted my-0">Vyplňte obsah jednou — propíše se do všech rozměrů najednou. Prázdné pole ponechá text ze šablony.</p>
                </div>
                <div class="d-flex align-items-center gap-2">
                    <a href="{{ path('template_group_editor', {'groupId': group.id}) }}" class="btn btn-outline-secondary rounded-pill"><i class="mdi mdi-pencil"></i> Upravit design</a>
                    <button type="submit" class="btn btn-primary rounded-pill" data-group-fill-target="exportButton">
                        <i class="mdi mdi-folder-zip-outline"></i> Stáhnout vše (ZIP)
                    </button>
                </div>
            </div>

            <div class="row">
                <div class="col-lg-4 col-xxl-3">
                    {% if text_inputs|length > 0 %}
                        <div class="card">
                            <div class="card-body">
                                <h4 class="header-title mb-3"><i class="mdi mdi-format-text"></i> Texty</h4>

                                {% for input in text_inputs %}
                                    <div class="mb-3">
                                        <div class="d-flex justify-content-between align-items-center">
                                            <label class="form-label mb-1" for="group-fill-text-{{ input.inputId }}">{{ input.name ?: 'Text ' ~ loop.index }}</label>
                                            {% if input.hidable %}
                                                <div class="form-check form-switch" title="Skrýt tento text ve všech rozměrech">
                                                    <input class="form-check-input" type="checkbox" value="1"
                                                           name="hiddenValues[{{ input.inputId }}]"
                                                           id="group-fill-hide-{{ input.inputId }}"
                                                           data-action="group-fill#changed">
                                                    <label class="form-check-label font-12 text-muted" for="group-fill-hide-{{ input.inputId }}">Skrýt</label>
                                                </div>
                                            {% endif %}
                                        </div>
                                        <input type="text"
                                               class="form-control{% if input.uppercase %} text-uppercase{% endif %}"
                                               id="group-fill-text-{{ input.inputId }}"
                                               name="textValues[{{ input.inputId }}]"
                                               value=""
                                               {% if input.maxLength %}maxlength="{{ input.maxLength }}"{% endif %}
                                               placeholder="Ponechat text ze šablony"
                                               autocomplete="off"
                                               data-action="input->group-fill#changed">
                                        {% if input.description %}
                                            <div class="form-text">{{ input.description }}</div>
                                        {% endif %}
                                    </div>
                                {% endfor %}
                            </div>
                        </div>
                    {% endif %}

                    {% if image_inputs|length > 0 %}
                        <div class="card">
                            <div class="card-body">
                                <h4 class="header-title mb-3"><i class="mdi mdi-image-outline"></i> Obrázky</h4>

                                {% for slot in image_inputs %}
                                    {% set input = slot.input %}
                                    <div class="mb-3">
                                        <div class="d-flex justify-content-between align-items-center">
                                            <label class="form-label mb-1">{{ input.name ?: 'Obrázek ' ~ loop.index }}</label>
                                            {% if input.hidable %}
                                                <div class="form-check form-switch" title="Skrýt tento obrázek ve všech rozměrech">
                                                    <input class="form-check-input" type="checkbox" value="1"
                                                           name="images[{{ input.inputId }}][hide]"
                                                           id="group-fill-image-hide-{{ input.inputId }}"
                                                           data-action="group-fill#changed">
                                                    <label class="form-check-label font-12 text-muted" for="group-fill-image-hide-{{ input.inputId }}">Skrýt</label>
                                                </div>
                                            {% endif %}
                                        </div>
                                        <div class="d-flex align-items-center gap-2">
                                            <span class="group-fill-image-thumb"
                                                  data-group-fill-target="imageThumb"
                                                  data-input-id="{{ input.inputId }}"
                                                  {% if slot.defaultImageUrl %}style="background-image: url('{{ slot.defaultImageUrl }}');"{% endif %}></span>
                                            {% if slot.images|length > 0 or slot.canUpload %}
                                                <button type="button" class="btn btn-sm btn-outline-secondary" data-bs-toggle="modal" data-bs-target="#groupFillImageModal-{{ input.inputId }}">
                                                    <i class="mdi mdi-image-search-outline"></i> {{ slot.canUpload ? 'Vybrat / nahrát obrázek' : 'Vybrat obrázek' }}
                                                </button>
                                            {% else %}
                                                <span class="text-muted font-12">Šablona nemá nastavenou složku galerie — kontaktujte správce šablony.</span>
                                            {% endif %}
                                        </div>
                                        {% if input.description %}
                                            <div class="form-text">{{ input.description }}</div>
                                        {% endif %}
                                        <input type="hidden" name="images[{{ input.inputId }}][imageId]" value=""
                                               data-group-fill-target="imageValue" data-input-id="{{ input.inputId }}">

                                        {# Placement the designer allowed. These edit the SHARED
                                           placement — dimensions the user unlinked keep their own.
                                           The primary interaction is dragging the picture in the
                                           preview itself; these are the precise counterpart. #}
                                        {% if input.allowMove or input.allowResize or input.allowRotate %}
                                            <div class="group-fill-placement-controls mt-2 d-none"
                                                 data-group-fill-target="placementControls"
                                                 data-input-id="{{ input.inputId }}">
                                                {% if input.allowResize %}
                                                    <label class="form-label font-12 text-muted mb-0 d-flex justify-content-between" for="group-fill-zoom-{{ input.inputId }}">
                                                        <span><i class="mdi mdi-magnify-plus-outline"></i> Zvětšení</span>
                                                        <span data-group-fill-target="zoomLabel" data-input-id="{{ input.inputId }}">100 %</span>
                                                    </label>
                                                    <input type="range" class="form-range" id="group-fill-zoom-{{ input.inputId }}"
                                                           min="1" max="4" step="0.01" value="1"
                                                           data-group-fill-target="zoomRange" data-input-id="{{ input.inputId }}"
                                                           data-action="input->group-fill#zoomChanged">
                                                    <input type="hidden" name="images[{{ input.inputId }}][scale]" value=""
                                                           data-group-fill-target="placementField"
                                                           data-input-id="{{ input.inputId }}" data-field="scale">
                                                {% endif %}
                                                {% if input.allowRotate %}
                                                    <label class="form-label font-12 text-muted mb-0 d-flex justify-content-between" for="group-fill-rotation-{{ input.inputId }}">
                                                        <span><i class="mdi mdi-rotate-right"></i> Otočení</span>
                                                        <span data-group-fill-target="rotationLabel" data-input-id="{{ input.inputId }}">0°</span>
                                                    </label>
                                                    <input type="range" class="form-range" id="group-fill-rotation-{{ input.inputId }}"
                                                           min="-180" max="180" step="1" value="0"
                                                           data-group-fill-target="rotationRange" data-input-id="{{ input.inputId }}"
                                                           data-action="input->group-fill#rotationChanged">
                                                    <input type="hidden" name="images[{{ input.inputId }}][rotation]" value=""
                                                           data-group-fill-target="placementField"
                                                           data-input-id="{{ input.inputId }}" data-field="rotation">
                                                {% endif %}
                                                {% if input.allowMove %}
                                                    {# Pan travels as a FRACTION of the frame so one value
                                                       lands correctly in every dimension's own frame. #}
                                                    <input type="hidden" name="images[{{ input.inputId }}][offsetXRatio]" value=""
                                                           data-group-fill-target="placementField"
                                                           data-input-id="{{ input.inputId }}" data-field="offsetXRatio">
                                                    <input type="hidden" name="images[{{ input.inputId }}][offsetYRatio]" value=""
                                                           data-group-fill-target="placementField"
                                                           data-input-id="{{ input.inputId }}" data-field="offsetYRatio">
                                                {% endif %}
                                                <div class="d-flex justify-content-between align-items-center gap-1 mt-1">
                                                    <span class="font-11 text-muted">
                                                        {% if input.allowMove %}Obrázek posunete tažením přímo v náhledu.{% endif %}
                                                    </span>
                                                    <button type="button" class="btn btn-link btn-sm p-0 font-12"
                                                            data-action="group-fill#resetPlacement"
                                                            data-group-fill-inputid-param="{{ input.inputId }}">Vycentrovat</button>
                                                </div>
                                            </div>
                                        {% endif %}
                                    </div>
                                {% endfor %}
                            </div>
                        </div>
                    {% endif %}

                    {% if text_inputs|length == 0 and image_inputs|length == 0 %}
                        <div class="card">
                            <div class="card-body text-muted">
                                <i class="mdi mdi-information-outline"></i>
                                Šablony ve skupině nemají žádné vyplnitelné prvky — export stáhne všechny rozměry tak, jak jsou navržené.
                            </div>
                        </div>
                    {% endif %}
                </div>

                <div class="col-lg-8 col-xxl-9">
                    <div class="row">
                        {% for v in variants %}
                            {% set variantId = v.variant.id %}
                            <div class="col-sm-6 col-xl-4">
                                <div class="card">
                                    <div class="group-fill-preview-frame" style="aspect-ratio: {{ v.width }} / {{ v.height }};">
                                        <img src="{{ uploaded_asset(v.variant.previewImagePath ?: v.variant.backgroundImage) }}"
                                             alt="{{ v.dimension_label }}"
                                             data-group-fill-target="preview"
                                             data-variant-id="{{ variantId }}"
                                             data-preview-endpoint="{{ v.preview_endpoint }}">
                                        {# Draggable stand-ins for the picked pictures, drawn where the
                                           server will render them in THIS dimension. Only visible while
                                           the user is placing (and until the fresh render lands). #}
                                        <div class="group-fill-placement-layer"
                                             data-group-fill-target="placementLayer"
                                             data-variant-id="{{ variantId }}"></div>
                                        <div class="group-fill-preview-spinner">
                                            <div class="spinner-border spinner-border-sm text-primary" role="status"></div>
                                        </div>
                                        <div class="group-fill-preview-error">Náhled se nepodařilo načíst</div>
                                    </div>
                                    <div class="card-body py-2 d-flex align-items-center justify-content-between gap-1">
                                        <span class="badge bg-secondary-lighten text-secondary">{{ v.module_label }}</span>
                                        <span class="text-muted font-12 text-end">{{ v.dimension_label }}</span>
                                    </div>
                                    {% if adjustable_image_inputs|length > 0 %}
                                        <div class="card-body pt-0 pb-2 d-none" data-group-fill-target="overrideBar" data-variant-id="{{ variantId }}">
                                            <button type="button" class="btn btn-link btn-sm p-0 font-12 text-decoration-none"
                                                    data-action="group-fill#toggleOverride"
                                                    data-group-fill-variantid-param="{{ variantId }}"
                                                    data-group-fill-target="overrideButton"
                                                    data-variant-id="{{ variantId }}">
                                                <i class="mdi mdi-link-variant"></i> Umístění podle společného
                                            </button>
                                            {# Per-dimension placement override. Empty = this dimension
                                               follows the shared placement; filled = it was unlinked. #}
                                            {% for slot in adjustable_image_inputs %}
                                                {% set input = slot.input %}
                                                {% if input.allowResize %}
                                                    <input type="hidden" name="imagePlacements[{{ variantId }}][{{ input.inputId }}][scale]" value=""
                                                           data-group-fill-target="overrideField"
                                                           data-variant-id="{{ variantId }}" data-input-id="{{ input.inputId }}" data-field="scale">
                                                {% endif %}
                                                {% if input.allowRotate %}
                                                    <input type="hidden" name="imagePlacements[{{ variantId }}][{{ input.inputId }}][rotation]" value=""
                                                           data-group-fill-target="overrideField"
                                                           data-variant-id="{{ variantId }}" data-input-id="{{ input.inputId }}" data-field="rotation">
                                                {% endif %}
                                                {% if input.allowMove %}
                                                    <input type="hidden" name="imagePlacements[{{ variantId }}][{{ input.inputId }}][offsetXRatio]" value=""
                                                           data-group-fill-target="overrideField"
                                                           data-variant-id="{{ variantId }}" data-input-id="{{ input.inputId }}" data-field="offsetXRatio">
                                                    <input type="hidden" name="imagePlacements[{{ variantId }}][{{ input.inputId }}][offsetYRatio]" value=""
                                                           data-group-fill-target="overrideField"
                                                           data-variant-id="{{ variantId }}" data-input-id="{{ input.inputId }}" data-field="offsetYRatio">
                                                {% endif %}
                                            {% endfor %}
                                        </div>
                                    {% endif %}
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                </div>
            </div>

            {# Image pickers: one modal per unified slot, plain thumbnails from
               the slot's allowed gallery folders + a "keep the designed
               picture" option, plus an upload field when the designer left the
               slot a folder to upload into. Picks land in the hidden imageId
               field; a fresh upload is appended as an option and auto-picked. #}
            {% for slot in image_inputs %}
                {% set input = slot.input %}
                {% if slot.images|length > 0 or slot.canUpload %}
                    <div class="modal fade" id="groupFillImageModal-{{ input.inputId }}" tabindex="-1" aria-hidden="true">
                        <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
                            <div class="modal-content">
                                <div class="modal-header">
                                    <h4 class="modal-title">{{ input.name ?: 'Vybrat obrázek' }}</h4>
                                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Zavřít"></button>
                                </div>
                                <div class="modal-body">
                                    <div class="d-flex flex-wrap gap-2"
                                         data-group-fill-target="imageOptions"
                                         data-input-id="{{ input.inputId }}">
                                        <button type="button" class="group-fill-image-option selected"
                                                data-action="group-fill#pickImage"
                                                data-input-id="{{ input.inputId }}"
                                                data-image-id=""
                                                data-image-url="{{ slot.defaultImageUrl ?: '' }}"
                                                data-bs-dismiss="modal"
                                                title="Ponechat obrázek ze šablony">
                                            {% if slot.defaultImageUrl %}
                                                <img src="{{ slot.defaultImageUrl }}" alt="Výchozí obrázek" loading="lazy">
                                            {% endif %}
                                            <span>Výchozí</span>
                                        </button>
                                        {% for image in slot.images %}
                                            <button type="button" class="group-fill-image-option"
                                                    data-action="group-fill#pickImage"
                                                    data-input-id="{{ input.inputId }}"
                                                    data-image-id="{{ image.id }}"
                                                    data-image-url="{{ image.url }}"
                                                    data-bs-dismiss="modal">
                                                <img src="{{ image.url }}" alt="" loading="lazy">
                                            </button>
                                        {% endfor %}
                                    </div>

                                    {% if slot.canUpload %}
                                        {% if slot.images|length == 0 %}
                                            <p class="text-muted small mt-2 mb-0">V povolených složkách galerie zatím nejsou žádné obrázky — nahrajte vlastní níže.</p>
                                        {% endif %}

                                        <hr class="my-3">

                                        {# The file input is deliberately UNNAMED so it never lands in
                                           the export FormData — the upload POSTs separately and the
                                           form only ever carries the resulting imageId. #}
                                        {% set uploadTargetCount = slot.directories|length + (slot.includesRoot ? 1 : 0) %}
                                        {% if uploadTargetCount > 1 %}
                                            <label class="form-label small text-muted mb-0" for="group-fill-upload-directory-{{ input.inputId }}">Nahrát do složky</label>
                                            <select id="group-fill-upload-directory-{{ input.inputId }}"
                                                    class="form-select form-select-sm mb-2"
                                                    data-upload-directory="{{ input.inputId }}">
                                                {% if slot.includesRoot %}
                                                    <option value="">Galerie (bez složky)</option>
                                                {% endif %}
                                                {% for directory in slot.directories %}
                                                    <option value="{{ directory.id }}">{{ directory.name }}</option>
                                                {% endfor %}
                                            </select>
                                        {% endif %}

                                        <label class="form-label small text-muted mb-0" for="group-fill-upload-file-{{ input.inputId }}">Nahrát vlastní obrázek <span class="text-muted">(JPG, PNG…)</span></label>
                                        <input type="file"
                                               id="group-fill-upload-file-{{ input.inputId }}"
                                               class="form-control form-control-sm"
                                               accept="image/*"
                                               data-action="change->group-fill#uploadImage"
                                               data-group-fill-inputid-param="{{ input.inputId }}"
                                               data-group-fill-uploadurl-param="{{ path('template_group_placeholder_upload', {'groupId': group.id, 'inputId': input.inputId}) }}">
                                        <div class="small mt-1" data-upload-status="{{ input.inputId }}" aria-live="polite"></div>
                                    {% endif %}
                                </div>
                            </div>
                        </div>
                    </div>
                {% endif %}
            {% endfor %}
        </form>
    {% endif %}
{% endblock %}
