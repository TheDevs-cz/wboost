<!DOCTYPE html>
<html lang="cs">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Schválení jídelníčku – {{ menu.name }}</title>
    <style>
        * { box-sizing: border-box; }
        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
            font-size: 14px;
            line-height: 1.5;
            margin: 0;
            padding: 20px;
            background-color: #f4f5f7;
            color: #333;
        }
        .container {
            max-width: 900px;
            margin: 0 auto;
        }
        .approval-card {
            background: #fff;
            border-radius: 8px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.1);
            padding: 32px;
            margin-bottom: 24px;
        }
        .approval-card h1 {
            margin: 0 0 8px;
            font-size: 24px;
            color: #333;
        }
        .approval-card .subtitle {
            color: #666;
            font-size: 15px;
            margin: 0 0 24px;
        }
        .status-badge {
            display: inline-block;
            padding: 6px 16px;
            border-radius: 20px;
            font-size: 14px;
            font-weight: 600;
            color: #fff;
        }
        .status-badge.approved { background-color: #10b981; }
        .status-badge.denied { background-color: #ef4444; }
        .status-badge.pending { background-color: #f59e0b; color: #333; }
        .form-group {
            margin-bottom: 20px;
        }
        .form-group label {
            display: block;
            margin-bottom: 6px;
            font-weight: 600;
            font-size: 14px;
            color: #333;
        }
        .form-group textarea {
            width: 100%;
            padding: 10px 14px;
            border: 1px solid #dee2e6;
            border-radius: 6px;
            font-size: 14px;
            font-family: inherit;
            resize: vertical;
            min-height: 80px;
        }
        .form-group textarea:focus {
            outline: none;
            border-color: #3b82f6;
            box-shadow: 0 0 0 3px rgba(59,130,246,0.15);
        }
        .btn {
            display: inline-block;
            padding: 12px 28px;
            border: none;
            border-radius: 6px;
            font-size: 15px;
            font-weight: 600;
            cursor: pointer;
            text-decoration: none;
            transition: opacity 0.15s;
        }
        .btn:hover { opacity: 0.9; }
        .btn-approve { background-color: #10b981; color: #fff; }
        .btn-deny { background-color: #ef4444; color: #fff; }
        .btn-group { display: flex; gap: 12px; flex-wrap: wrap; }
        .result-message {
            text-align: center;
            padding: 40px 20px;
        }
        .result-message .icon {
            font-size: 48px;
            margin-bottom: 16px;
        }
        .result-message h2 {
            margin: 0 0 8px;
            font-size: 22px;
        }
        .result-message p {
            color: #666;
            font-size: 15px;
            margin: 0;
        }
        .menu-preview {
            margin-top: 24px;
            border-top: 1px solid #e9ecef;
            padding-top: 24px;
        }
        .menu-preview h3 {
            margin: 0 0 16px;
            font-size: 16px;
            color: #666;
        }
        .comment-display {
            background-color: #fff3cd;
            border-left: 4px solid #ffc107;
            border-radius: 4px;
            padding: 12px 16px;
            margin-top: 16px;
        }
        .comment-display .label {
            font-weight: 600;
            font-size: 13px;
            color: #856404;
            margin-bottom: 4px;
        }
        .comment-display .text {
            color: #856404;
            font-size: 14px;
        }

        @media (max-width: 640px) {
            body { padding: 12px; }
            .approval-card { padding: 20px; }
            .btn-group { flex-direction: column; }
            .btn { text-align: center; }
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="approval-card">
            {% if submitted is defined and submitted %}
                <div class="result-message">
                    {% if action == 'approve' %}
                        <div class="icon">&#10004;</div>
                        <h2>Jídelníček byl schválen</h2>
                        <p>Děkujeme za vaše rozhodnutí. Autor jídelníčku byl informován.</p>
                    {% else %}
                        <div class="icon">&#10006;</div>
                        <h2>Jídelníček byl zamítnut</h2>
                        <p>Děkujeme za vaše rozhodnutí. Autor jídelníčku byl informován.</p>
                    {% endif %}
                </div>
            {% elseif alreadyResponded %}
                <div class="result-message">
                    <h2>Již bylo rozhodnuto</h2>
                    <p>
                        Tento jídelníček byl
                        {% if menu.approvalStatus.value == 'approved' %}
                            <span class="status-badge approved">schválen</span>
                        {% elseif menu.approvalStatus.value == 'denied' %}
                            <span class="status-badge denied">zamítnut</span>
                        {% else %}
                            upraven od posledního schválení
                        {% endif %}
                        {% if menu.approvalRespondedAt %}
                            dne {{ menu.approvalRespondedAt|date('d.m.Y H:i') }}
                        {% endif %}
                    </p>
                    {% if menu.approvalComment is not empty %}
                        <div class="comment-display" style="text-align: left; margin-top: 20px;">
                            <div class="label">Komentář:</div>
                            <div class="text">{{ menu.approvalComment }}</div>
                        </div>
                    {% endif %}
                </div>
            {% else %}
                <h1>Schválení jídelníčku</h1>
                <p class="subtitle">
                    <strong>{{ menu.name }}</strong>
                    &middot; Platnost: {{ menu.validFrom|date('d.m.Y') }} – {{ menu.validTo|date('d.m.Y') }}
                </p>

                <form method="post">
                    <div class="form-group">
                        <label for="comment">Komentář (volitelný)</label>
                        <textarea id="comment" name="comment" placeholder="Můžete přidat komentář k vašemu rozhodnutí..."></textarea>
                    </div>

                    <div class="btn-group">
                        <button type="submit" name="action" value="approve" class="btn btn-approve">
                            Schválit
                        </button>
                        <button type="submit" name="action" value="deny" class="btn btn-deny">
                            Zamítnout
                        </button>
                    </div>
                </form>

                <div class="menu-preview">
                    <h3>Náhled jídelníčku</h3>
                    {% include 'weekly_menu/_menu_display.html.twig' with { menu: menu, showFooter: true } %}
                </div>
            {% endif %}
        </div>
    </div>
</body>
</html>
