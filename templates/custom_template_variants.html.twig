{% extends 'base.html.twig' %}

{% set active_menu_item = 'custom_templates' %}

{% block title %}Šablony - varianty{% endblock %}

{% block breadcrumb %}
    <ol class="breadcrumb m-0 pt-0">
        <li class="breadcrumb-item"><i class="uil-home-alt"></i> <a href="{{ path('homepage') }}">Projekty</a></li>
        <li class="breadcrumb-item"><a href="{{ path('project_dashboard', {'id': project.id}) }}">{{ project.name }}</a></li>
        <li class="breadcrumb-item"><a href="{{ path('custom_templates', {'projectId': project.id}) }}">Šablony</a></li>
        <li class="breadcrumb-item active">{{ template.name }}</li>
    </ol>
{% endblock %}

{% block content %}
    <div class="card">
        <div class="card-body">
            <h2 class="h3 mt-0 mb-3">
                Varianty

                {% if is_granted('ROLE_DESIGNER') %}
                    <a href="{{ path('add_custom_template_variant', {'templateId': template.id}) }}" class="btn btn-outline-primary rounded-pill float-end btn-sm"><i class="mdi mdi-plus"></i> Přidat</a>
                {% endif %}
            </h2>

            <div class="row">
                {% for variant in variants %}
                    <div class="col-md-3 col-6">
                        <div class="card">
                            {% if is_granted('project_edit', project) %}
                                <div class="card-img-overlay dropdown card-widgets p-2" style="left: auto;bottom: auto;">
                                    <a href="#" class="dropdown-toggle arrow-none d-inline-block bg-light text-center rounded-4 text-black" data-bs-toggle="dropdown" aria-expanded="false" style="width: 30px;height: 30px;line-height: 30px;">
                                        <i class="ri-more-fill text-lighter"></i>
                                    </a>
                                    <div class="dropdown-menu dropdown-menu-end">
                                        {% if variant.group and is_granted('ROLE_DESIGNER') %}
                                            <a href="{{ path('template_group_editor', {'groupId': variant.group.id}) }}" class="dropdown-item"><i class="uil-layer-group me-1"></i>Upravit ve skupině</a>
                                        {% endif %}
                                        <a href="{{ path('copy_custom_template_variant', {'variantId': variant.id}) }}" class="dropdown-item"><i class="mdi mdi-content-copy me-1"></i>Duplikovat</a>
                                        <a href="{{ path('custom_template_variant_export', {'variantId': variant.id}) }}" class="dropdown-item"><i class="mdi mdi-export me-1"></i>Export</a>
                                        <a href="#"
                                           class="dropdown-item"
                                           data-modal-id="{{ variant.id }}"
                                           data-action="click->confirm-modal#showModal">
                                            <i class="mdi mdi-delete me-1"></i> Smazat
                                        </a>
                                    </div>
                                </div>

                                <twig:ConfirmModal
                                    id="{{ variant.id }}"
                                    url="{{ path('delete_custom_template_variant', {'variantId': variant.id}) }}"
                                    confirmationText="Opravdu chcete smazat tuto variantu šablony?" />
                            {% endif %}

                            <a href="{{ is_granted('custom_template_variant_edit', variant) ? path('custom_template_variant_editor', {'variantId': variant.id}) : path('custom_template_variant_export', {'variantId': variant.id}) }}" class="text-body">
                                <div class="card-body p-1 shadow-lg">
                                    <img src="{{ uploaded_asset(variant.previewImagePath ?: variant.backgroundImage) }}" style="max-width: 100%;">
                                </div>
                                <div class="card-body py-1 px-2">
                                    <p class="small text-muted my-0">
                                        {{ variant.dimension.label }}
                                        {% if variant.group and is_granted('ROLE_DESIGNER') %}
                                            <span class="badge bg-info-lighten text-info float-end" title="Součást skupiny {{ variant.group.name }}"><i class="uil-layer-group"></i> Skupina</span>
                                        {% endif %}
                                    </p>
                                </div>
                            </a>
                        </div>
                    </div>
                {% endfor %}
            </div>
        </div>
    </div>
{% endblock %}
