<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <title>render</title>
    <style>
        html, body { margin: 0; padding: 0; background: transparent; }
        canvas { display: block; }

        {% for face in font_faces %}
            @font-face {
                font-family: '{{ face.family }}';
                src: url('{{ face.src }}');
            }
        {% endfor %}
    </style>
    {# Fabric v7 UMD bundle (exposes the global `fabric` namespace —
       `fabric.StaticCanvas`, `fabric.Canvas`, ... — the same way v5 did).
       Inlined by SocialNetworkTemplateVariantImageRenderer from the file
       committed at assets/fabric/fabric-7.3.1.min.js so the headless render
       has no outbound network dependency on jsDelivr. To upgrade, replace
       the file (and the path on the renderer service) with a new pinned
       version. #}
    <script>{{ fabric_inline_script|raw }}</script>
</head>
<body>
    <canvas id="c" width="{{ variant.dimension.width }}" height="{{ variant.dimension.height }}"></canvas>

    <script>
        (async () => {
            try {
                // Wait for inlined fonts to be parsed and ready before any text measurement.
                if (document.fonts && document.fonts.ready) {
                    await document.fonts.ready;
                }

                const canvasJson = {{ canvas_json|raw }};
                const textOverrides = {{ text_overrides|json_encode|raw }};
                const hiddenOverrides = {{ hidden_overrides|json_encode|raw }};

                const canvas = new fabric.StaticCanvas('c', {
                    width: {{ variant.dimension.width }},
                    height: {{ variant.dimension.height }},
                    enableRetinaScaling: false,
                });

                // Fabric v7: loadFromJSON is Promise-based; the callback
                // form was removed. Await the load, then apply overrides.
                await canvas.loadFromJSON(canvasJson);

                // Fabric v7's _fromObject does NOT copy arbitrary custom
                // properties from the source JSON onto the deserialized
                // instance — only known stateProperties survive. So our
                // `inputId` (and friends) end up undefined on the live
                // objects unless we restore them ourselves. Without this
                // step, the override-by-inputId lookup below silently
                // matches nothing and the placeholder text is rendered
                // verbatim. (Confirmed against the v7 source: pick(this,
                // propertiesToSerialize) on toObject, with no symmetric
                // hydrate on _fromObject.)
                const CANVAS_CUSTOM_PROPERTIES = [
                    'inputId', 'name', 'maxLength',
                    'locked', 'uppercase', 'description', 'hidable',
                ];
                const sourceObjects = Array.isArray(canvasJson.objects) ? canvasJson.objects : [];
                const liveObjects = canvas.getObjects();
                liveObjects.forEach((obj, idx) => {
                    const source = sourceObjects[idx];
                    if (!source) return;
                    CANVAS_CUSTOM_PROPERTIES.forEach((prop) => {
                        if (source[prop] !== undefined) {
                            obj[prop] = source[prop];
                        }
                    });
                });

                // Apply overrides by inputId — see Stage 2 of the Fabric
                // migration. We walk all objects (not just 'textbox') so
                // future image-placeholder inputs use the same lookup path.
                Object.keys(textOverrides).forEach((idKey) => {
                    const obj = liveObjects.find((o) => o.inputId === idKey);
                    if (obj) {
                        obj.text = String(textOverrides[idKey]);
                    }
                });
                Object.keys(hiddenOverrides).forEach((idKey) => {
                    const obj = liveObjects.find((o) => o.inputId === idKey);
                    if (obj) {
                        obj.visible = !hiddenOverrides[idKey];
                    }
                });

                canvas.renderAll();

                // Two RAFs to let the browser commit the rendered pixels before signaling.
                await new Promise((resolve) => {
                    requestAnimationFrame(() => requestAnimationFrame(resolve));
                });

                window.canvasRendered = true;
            } catch (err) {
                window.canvasRenderError = String(err && err.stack || err);
                window.canvasRendered = true;
            }
        })();
    </script>
</body>
</html>
