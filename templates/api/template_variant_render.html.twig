<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <title>render</title>
    <style>
        html, body { margin: 0; padding: 0; background: transparent; }
        canvas { display: block; }
    </style>
    {# Fabric v7 UMD bundle (exposes the global `fabric` namespace —
       `fabric.StaticCanvas`, `fabric.Canvas`, ... — the same way v5 did).
       Inlined by TemplateVariantImageRenderer from the file
       committed at assets/fabric/fabric-7.3.1.min.js so the headless render
       has no outbound network dependency on jsDelivr. To upgrade, replace
       the file (and the path on the renderer service) with a new pinned
       version. #}
    <script>{{ fabric_inline_script|raw }}</script>
    {# Shared editor modules, inlined for the same no-outbound-network reason.
       fabric_break_word.js patches Textbox wrapping (must match the editor +
       fill page exactly — container reflow correctness rests on identical
       text measurement everywhere); container_layout.js is the single source
       of truth for the "smart text area" reflow algorithm. #}
    <script>{{ break_word_inline_script|raw }}</script>
    <script>{{ container_layout_inline_script|raw }}</script>
</head>
<body>
    <canvas id="c" width="{{ variant.dimension.width }}" height="{{ variant.dimension.height }}"></canvas>

    <script>
        (async () => {
            try {
                // Force-load every project font face BEFORE any canvas text
                // measurement / rendering. This is the crux of the "export
                // uses the wrong font" bug: a Canvas 2D context does NOT
                // trigger lazy @font-face loading, and `document.fonts.ready`
                // only awaits faces that are ALREADY loading — so a purely
                // declarative @font-face is never fetched for canvas-only text
                // and Fabric silently renders with a serif fallback. The
                // editor avoids this by explicitly loading fonts via
                // FontFaceObserver; here we construct FontFace objects from the
                // inlined data URIs and await load(), which guarantees the
                // glyphs are resident before Fabric measures or paints.
                const fontFaces = {{ font_faces|json_encode|raw }};
                await Promise.all(fontFaces.map(async (face) => {
                    try {
                        const fontFace = new FontFace(face.family, 'url("' + face.src + '")');
                        await fontFace.load();
                        document.fonts.add(fontFace);
                    } catch (fontErr) {
                        // A single missing/corrupt face must not abort the whole
                        // render — fall back for that family only.
                        console.error('Font load failed: ' + face.family, fontErr);
                    }
                }));

                if (document.fonts && document.fonts.ready) {
                    await document.fonts.ready;
                }

                const canvasJson = {{ canvas_json|raw }};
                const textOverrides = {{ text_overrides|json_encode|raw }};
                const hiddenOverrides = {{ hidden_overrides|json_encode|raw }};
                const containers = {{ containers|json_encode|raw }};
                const strictContainerOverflow = {{ strict_container_overflow ? 'true' : 'false' }};

                // overflow-wrap: break-word for Textbox — shared module (see
                // assets/editor/fabric_break_word.js, inlined in <head>), the
                // exact same patch the admin editor and the fill page apply so
                // all three surfaces wrap text identically.
                WBoostFabricBreakWord.enable(fabric.Textbox);

                const canvas = new fabric.StaticCanvas('c', {
                    width: {{ variant.dimension.width }},
                    height: {{ variant.dimension.height }},
                    enableRetinaScaling: false,
                });

                // Fabric v7: loadFromJSON is Promise-based; the callback
                // form was removed. Await the load, then apply overrides.
                await canvas.loadFromJSON(canvasJson);

                // Normalize the background to object-fit: cover / center center,
                // matching the editor's coverBackgroundImage. Canvases saved
                // before the cover fix (and the empty-canvas synthesis) carry a
                // center origin with no scale; under Fabric v7's center/center
                // default that crops the background to its bottom-right quadrant.
                // Recompute from the image's natural size so the exported PNG
                // bleeds the background to every edge, exactly like the editor.
                const backgroundImage = canvas.backgroundImage;
                if (backgroundImage) {
                    const element = typeof backgroundImage.getElement === 'function' ? backgroundImage.getElement() : null;
                    const naturalWidth = (element && (element.naturalWidth || element.width)) || backgroundImage.width || 1;
                    const naturalHeight = (element && (element.naturalHeight || element.height)) || backgroundImage.height || 1;
                    const coverScale = Math.max(canvas.width / naturalWidth, canvas.height / naturalHeight);
                    backgroundImage.set({
                        width: naturalWidth,
                        height: naturalHeight,
                        cropX: 0,
                        cropY: 0,
                        originX: 'center',
                        originY: 'center',
                        left: canvas.width / 2,
                        top: canvas.height / 2,
                        scaleX: coverScale,
                        scaleY: coverScale,
                    });
                }

                // Fabric v7's _fromObject does NOT copy arbitrary custom
                // properties from the source JSON onto the deserialized
                // instance — only known stateProperties survive. So our
                // `inputId` (and friends) end up undefined on the live
                // objects unless we restore them ourselves. Without this
                // step, the override-by-inputId lookup below silently
                // matches nothing and the placeholder text is rendered
                // verbatim. (Confirmed against the v7 source: pick(this,
                // propertiesToSerialize) on toObject, with no symmetric
                // hydrate on _fromObject.)
                const CANVAS_CUSTOM_PROPERTIES = [
                    'inputId', 'name', 'maxLength',
                    'locked', 'uppercase', 'description', 'hidable',
                ];
                const sourceObjects = Array.isArray(canvasJson.objects) ? canvasJson.objects : [];
                const liveObjects = canvas.getObjects();
                liveObjects.forEach((obj, idx) => {
                    const source = sourceObjects[idx];
                    if (!source) return;
                    CANVAS_CUSTOM_PROPERTIES.forEach((prop) => {
                        if (source[prop] !== undefined) {
                            obj[prop] = source[prop];
                        }
                    });
                });

                // Container reflow, phase A — BEFORE overrides, while every
                // member still holds its designed text: snapshot the designed
                // geometry (anchor top + inter-member gaps) the reflow is
                // computed against. Must run after the custom-prop restore
                // above (members are resolved by inputId).
                const preparedContainers = WBoostContainerLayout.prepareFabricContainers(liveObjects, containers);

                // Apply overrides by inputId. CRITICAL: use `obj.set(...)`
                // and NOT direct property assignment. Fabric v7's Textbox
                // caches glyph layout / dimensions / styleMap and only
                // invalidates them through the property-setter chain that
                // `set()` runs. A bare `obj.text = newText` updates the
                // string state but the rendered output keeps the OLD
                // glyphs — exactly the iteration-6 production bug where
                // the canvas kept showing the placeholder despite the
                // override clearly being applied at the JS level.
                // Verified empirically via /debug/fabric-render-test.html
                // against the prod canvas JSON.
                Object.keys(textOverrides).forEach((idKey) => {
                    const obj = liveObjects.find((o) => o.inputId === idKey);
                    if (obj) {
                        obj.set({ text: String(textOverrides[idKey]) });
                    }
                });
                Object.keys(hiddenOverrides).forEach((idKey) => {
                    const obj = liveObjects.find((o) => o.inputId === idKey);
                    if (obj) {
                        obj.set({ visible: !hiddenOverrides[idKey] });
                    }
                });

                // Container reflow, phase B — AFTER overrides: every member
                // Textbox has re-wrapped to its real height, so shift members
                // down/up along the designed gaps (hidden members collapse).
                const containerResults = WBoostContainerLayout.applyFabricLayout(preparedContainers);
                const overflowing = containerResults.find((result) => result.overflowPx > 0);
                if (strictContainerOverflow && overflowing) {
                    // The screenshot response can only carry an image, so the
                    // overflow signal travels as an uncaught console exception:
                    // Gotenberg (failOnConsoleExceptions) fails the conversion
                    // and echoes the marker below back in its error body, where
                    // TemplateVariantImageRenderer parses it into a
                    // ContainerOverflow (→ API 400). setTimeout escapes both
                    // this try/catch and the async function body on purpose —
                    // it must surface as an UNCAUGHT exception. canvasRendered
                    // is still flipped at the end so waitForExpression never
                    // times out.
                    setTimeout(() => {
                        throw new Error('CONTAINER_OVERFLOW:' + JSON.stringify({
                            containerId: overflowing.id,
                            overflowPx: Math.round(overflowing.overflowPx * 100) / 100,
                        }));
                    }, 0);
                }

                canvas.renderAll();

                // Two RAFs to let the browser commit the rendered pixels before signaling.
                await new Promise((resolve) => {
                    requestAnimationFrame(() => requestAnimationFrame(resolve));
                });

                window.canvasRendered = true;
            } catch (err) {
                window.canvasRenderError = String(err && err.stack || err);
                window.canvasRendered = true;
            }
        })();
    </script>
</body>
</html>
