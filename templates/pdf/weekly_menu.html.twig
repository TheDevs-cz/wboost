<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>{{ menu.name }}</title>
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;700&subset=latin-ext&display=swap" rel="stylesheet">
    <script>document.fonts.ready.then(function() { window.fontsReady = true; });</script>
    <style>
        * {
            box-sizing: border-box;
        }

        html, body {
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Roboto', DejaVu Sans, sans-serif;
            font-size: 18px;
            line-height: 1.3;
            color: #636463;
            display: flex;
            flex-direction: column;
            height: 100vh;
        }

        .header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 4mm;
            padding: 0 5mm;
        }

        .header h1 {
            margin: 0;
            font-size: 42px;
            font-weight: bold;
            text-align: left;
        }

        .header-note {
            font-size: 18px;
            text-align: right;
            white-space: nowrap;
        }

        .days-container {
            flex: 1;
            display: flex;
            flex-direction: column;
            padding: 0 5mm;
            gap: 2mm;
        }

        .day-row {
            flex: 1 1 auto;
            display: flex;
            flex-direction: row;
        }

        .day-label {
            width: 4%;
            font-weight: bold;
            font-size: 38px;
            text-align: center;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            border: 0.5px solid #636463;
        }

        .meal-cell {
            display: flex;
            flex-direction: column;
            border: 0.5px solid #636463;
            border-left-width: 0;
            min-height: 0;
        }

        .meal-cell-first {
            border-left-width: 0.5px;
        }

        .meal-cell-last {
            border-right-width: 1px;
        }

        .meal-cell-small {
            width: 12.5%;
        }

        .meal-cell-large {
            width: 31.25%;
        }

        .meal-cell-header {
            font-weight: bold;
            text-align: center;
            font-size: 18px;
            padding: 4px 3px;
            border-bottom: 0.5px solid #636463;
        }

        .meal-cell-content {
            flex: 1;
            display: flex;
            flex-direction: column;
            font-size: 18px;
            text-align: center;
            min-height: 0;
        }

        .course-block {
            margin: 0;
            padding: 0;
        }

        .course-block-last {
            flex: 1;
            display: flex;
            flex-direction: column;
        }

        .course-content {
            padding: 4px;
            text-align: center;
        }

        .course-separator {
            border-top: 0.5px solid #636463;
        }

        .variants-table {
            width: 100%;
            border-collapse: collapse;
            border: 0;
            flex: 1;
            height: 100%;
        }

        .variants-table .variant-header-row {
            height: 1px;
        }

        .variants-table .variant-content-row {
            height: 100%;
        }

        .variant-header {
            text-align: center;
            vertical-align: middle;
            font-weight: bold;
            font-size: 16px;
            padding: 3px 3px;
            border-bottom: 0.5px solid #636463;
            border-left: 0.5px solid #636463;
        }

        .variant-header-first {
            border-left: none;
        }

        .variant-content {
            vertical-align: top;
            text-align: center;
            padding: 4px;
            border-left: 0.5px solid #636463;
            border-bottom: 0;
        }

        .variant-content-first {
            border-left: none;
        }

        .diet-badge {
            background: #68ACD2;
            color: white;
            font-size: 13px;
            padding: 2px 4px;
            border-radius: 3px;
            margin-right: 3px;
            font-weight: bold;
            display: inline-block;
        }

        .diet-badge-last {
            margin-right: 3px;
        }

        .diet-badge sup {
            font-size: 9px;
        }

        .meal-line {
            margin-bottom: 2px;
            line-height: 1.0;
        }

        .meal-variant-line {
            margin-bottom: 2px;
            line-height: 1.0;
        }

        .course-soup {
            border-top: 0.5px solid #636463;
        }

        .course-soup-first {
            border-top: none;
        }

        .footer {
            text-align: center;
            font-size: 16px;
            color: #636463;
            padding: 4mm 5mm 0 5mm;
        }

        .footer-line {
            margin-bottom: 2px;
        }
    </style>
</head>
<body>
    {% macro renderMeals(variant) %}
        {% for variantMeal in variant.meals %}
            <div class="meal-line">
                {%- if variantMeal.meal.hasDiets -%}
                    {%- set allCodes = [] -%}
                    {%- for diet in variantMeal.meal.diets -%}
                        {%- for code in diet.dietCodes -%}
                            {%- set allCodes = allCodes|merge([code]) -%}
                        {%- endfor -%}
                    {%- endfor -%}
                    {%- for code in allCodes -%}
                        <span class="diet-badge{% if loop.last %} diet-badge-last{% endif %}">{{ code.value|replace({'9/2': '9<sup>2</sup>'})|raw }}</span>
                    {%- endfor -%}
                {%- endif -%}
                {{ variantMeal.meal.name }}
            </div>
            {% if variantMeal.meal.hasVariants %}
                {% for mealVariant in variantMeal.meal.variants %}
                    <div class="meal-variant-line">
                        {%- if mealVariant.effectiveDiets|length > 0 -%}
                            {%- set allCodes = [] -%}
                            {%- for diet in mealVariant.effectiveDiets -%}
                                {%- for code in diet.dietCodes -%}
                                    {%- set allCodes = allCodes|merge([code]) -%}
                                {%- endfor -%}
                            {%- endfor -%}
                            {%- for code in allCodes -%}
                                <span class="diet-badge{% if loop.last %} diet-badge-last{% endif %}">{{ code.value|replace({'9/2': '9<sup>2</sup>'})|raw }}</span>
                            {%- endfor -%}
                        {%- endif -%}
                        {{ mealVariant.displayName }}
                    </div>
                {% endfor %}
            {% endif %}
        {% endfor %}
    {% endmacro %}

    {% import _self as macros %}

    {% set mealTypeOrder = ['breakfast', 'lunch', 'snack', 'dinner', 'late_dinner'] %}
    {% set mealTypeLabels = {
        'breakfast': 'Snídaně',
        'lunch': 'Oběd',
        'dinner': 'Večeře',
        'snack': 'Svačina',
        'late_dinner': 'II. Večeře'
    } %}

    {% set dayColors = {
        1: '#68ACD2',
        2: '#94BF6A',
        3: '#EAC157',
        4: '#D68142',
        5: '#AD3533',
        6: '#9F9F9E',
        7: '#636463'
    } %}
    {% set dayLightColors = {
        1: '#d2e6f2',
        2: '#dfecd2',
        3: '#f9eccd',
        4: '#f3d9c6',
        5: '#e6c2c2',
        6: '#e2e2e2',
        7: '#d0d1d0'
    } %}
    {% set dayHeaderColors = {
        1: '#e8f3f9',
        2: '#eff6e8',
        3: '#fcf5e6',
        4: '#f9ece2',
        5: '#f2e0e0',
        6: '#f0f0f0',
        7: '#e7e8e7'
    } %}

    <div class="header">
        <h1>{{ menu.name }} &ndash; od {{ menu.validFrom|date('j. n.') }} do {{ menu.validTo|date('j. n. Y') }}</h1>
        <div class="header-note">Na požádání lze připravit i vegetariánskou stravu.</div>
    </div>

    <div class="days-container">
        {% for day in menu.days %}
            {% set mealTypeMap = {} %}
            {% for mt in day.mealTypes %}
                {% set mealTypeMap = mealTypeMap|merge({ (mt.mealType.value): mt }) %}
            {% endfor %}

            {% set dayBg = dayColors[day.dayOfWeek] ?? '#636463' %}
            {% set dayLightBg = dayLightColors[day.dayOfWeek] ?? '#d0d1d0' %}
            {% set dayHeaderBg = dayHeaderColors[day.dayOfWeek] ?? '#e7e8e7' %}

            <div class="day-row">
                <div class="day-label" style="background-color: {{ dayBg }}">{{ day.dayLabelShort }}</div>
                {% for mealTypeKey in mealTypeOrder %}
                    <div class="meal-cell{% if loop.first %} meal-cell-first{% endif %}{% if loop.last %} meal-cell-last{% endif %}{% if mealTypeKey == 'lunch' or mealTypeKey == 'dinner' %} meal-cell-large{% else %} meal-cell-small{% endif %}">
                        <div class="meal-cell-header" style="background-color: {{ dayHeaderBg }}">{{ mealTypeLabels[mealTypeKey] }}</div>
                        <div class="meal-cell-content">
                            {% if mealTypeMap[mealTypeKey] is defined %}
                                {% set mealTypeData = mealTypeMap[mealTypeKey] %}
                                {% for course in mealTypeData.courses %}
                                    {% set hasMeals = false %}
                                    {% for variant in course.variants %}
                                        {% if variant.meals|length > 0 %}
                                            {% set hasMeals = true %}
                                        {% endif %}
                                    {% endfor %}
                                    {% if hasMeals %}
                                    {% set isSoup = course.containsDishType('Polévka') %}
                                    {% set nextCourse = mealTypeData.courses[loop.index] ?? null %}
                                    {% set nextIsVariant = nextCourse and not nextCourse.singleVariantMode and nextCourse.variants|length >= 1 %}
                                    <div class="course-block{% if loop.last %} course-block-last{% endif %}{% if not loop.first %} course-separator{% endif %}{% if isSoup %} course-soup{% if loop.first %} course-soup-first{% endif %}{% if loop.last or nextIsVariant %} course-soup-last{% endif %}{% endif %}">
                                        {% set variants = course.variants %}
                                        {% if not course.singleVariantMode and variants|length >= 1 %}
                                            <table class="variants-table">
                                                <tr class="variant-header-row">
                                                    {% for variant in variants %}
                                                        <td class="variant-header{% if loop.first %} variant-header-first{% endif %}" style="width: {{ (100 / variants|length)|round }}%; background-color: {{ dayLightBg }}">{{ loop.index }}.</td>
                                                    {% endfor %}
                                                </tr>
                                                <tr class="variant-content-row">
                                                    {% for variant in variants %}
                                                        <td class="variant-content{% if loop.first %} variant-content-first{% endif %}">
                                                            {{ macros.renderMeals(variant) }}
                                                        </td>
                                                    {% endfor %}
                                                </tr>
                                            </table>
                                        {% else %}
                                            <div class="course-content">
                                                {% for variant in variants %}
                                                    {{ macros.renderMeals(variant) }}
                                                {% endfor %}
                                            </div>
                                        {% endif %}
                                    </div>
                                    {% endif %}
                                {% endfor %}
                            {% endif %}
                        </div>
                    </div>
                {% endfor %}
            </div>
        {% endfor %}
    </div>

    <div class="footer">
        <div class="footer-line">
            {% if menu.createdBy %}<strong>Sestavila:</strong> {{ menu.createdBy }}{% endif %}
            {% if menu.createdBy and menu.approvedBy %} | {% endif %}
            {% if menu.approvedBy %}<strong>Schválila:</strong> {{ menu.approvedBy }}{% endif %}
            | Změna jídelníčku vyhrazena | Seznamu alergenů na vyžádání u vedoucí kuchyně
        </div>
    </div>
</body>
</html>
