{% extends 'base.html.twig' %}

{% block title %}Nastavení hesla{% endblock %}

{% block body_class %}authentication-bg position-relative{% endblock %}

{% block full_content %}
    <div class="position-absolute start-0 end-0 start-0 bottom-0 w-100 h-100">
        <svg xmlns="http://www.w3.org/2000/svg" width="100%" height="100%" viewBox="0 0 800 800">
            <g fill-opacity="0.22">
                <circle style="fill: rgba(var(--ct-primary-rgb), 0.1);" cx="400" cy="400" r="600"></circle>
                <circle style="fill: rgba(var(--ct-primary-rgb), 0.2);" cx="400" cy="400" r="500"></circle>
                <circle style="fill: rgba(var(--ct-primary-rgb), 0.3);" cx="400" cy="400" r="300"></circle>
                <circle style="fill: rgba(var(--ct-primary-rgb), 0.4);" cx="400" cy="400" r="200"></circle>
                <circle style="fill: rgba(var(--ct-primary-rgb), 0.5);" cx="400" cy="400" r="100"></circle>
            </g>
        </svg>
    </div>

    <div class="account-pages pt-2 pt-sm-5 pb-4 pb-sm-5 position-relative">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-xxl-4 col-lg-5">
                    <div class="card">

                        <!-- Logo -->
                        <div class="card-header py-4 text-center bg-dark">
                            <span><img src="{{ asset('images/logo-lg.svg') }}" alt="logo" height="22"></span>
                        </div>

                        <div class="card-body p-4">
                            {{ include('_flashes.html.twig') }}

                            {% if invalid %}
                                <div class="text-center w-75 m-auto">
                                    <h4 class="text-dark-50 text-center mt-0 fw-bold">Odkaz vypršel</h4>
                                    <p class="text-muted mb-4">Tento odkaz pro nastavení hesla je neplatný nebo již vypršel. Nechte si poslat nový.</p>
                                </div>

                                <div class="mb-0 text-center">
                                    <a class="btn btn-primary" href="{{ path('forgotten_password') }}">Poslat nový odkaz</a>
                                </div>
                            {% else %}
                                <div class="text-center w-75 m-auto">
                                    {% if isInvitation %}
                                        <h4 class="text-dark-50 text-center mt-0 fw-bold">Vítejte ve WBoost</h4>
                                        <p class="text-muted mb-4">Pro aktivaci účtu si nastavte heslo.</p>
                                    {% else %}
                                        <h4 class="text-dark-50 text-center mt-0 fw-bold">Zvolte si nové heslo</h4>
                                        <p class="text-muted mb-4">Zadejte si nové heslo k vašemu účtu.</p>
                                    {% endif %}
                                </div>

                                {{ form_start(form) }}
                                {{ form_row(form.password.first) }}
                                {{ form_row(form.password.second) }}

                                <div class="mb-0 text-center">
                                    <button class="btn btn-primary" type="submit">
                                        {{ isInvitation ? 'Nastavit heslo a aktivovat účet' : 'Změnit heslo' }}
                                    </button>
                                </div>
                                {{ form_end(form) }}
                            {% endif %}
                        </div>
                    </div>
                    <!-- end card -->

                    <div class="row mt-3">
                        <div class="col-12 text-center">
                            <p class="text-muted">Zpět na <a href="{{ path('login') }}" class="text-muted ms-1"><b>přihlášení</b></a></p>
                        </div> <!-- end col -->
                    </div>
                    <!-- end row -->

                </div> <!-- end col -->
            </div>
            <!-- end row -->
        </div>
        <!-- end container -->
    </div>
{% endblock %}
