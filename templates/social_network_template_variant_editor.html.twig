{% extends 'base.html.twig' %}

{% set active_menu_item = 'social_networks' %}

{% block title %}Editor - Varianta {{ variant.dimension.value}} ({{ variant.dimension.width }}x{{ variant.dimension.height }}){% endblock %}

{% block breadcrumb %}
    <ol class="breadcrumb m-0 pt-0">
        <li class="breadcrumb-item"><i class="uil-home-alt"></i> <a href="{{ path('homepage') }}">Projekty</a></li>
        <li class="breadcrumb-item"><a href="{{ path('project_dashboard', {'id': project.id}) }}">{{ project.name }}</a></li>
        <li class="breadcrumb-item"><a href="{{ path('social_network_templates', {'projectId': project.id}) }}">Sociální sítě</a></li>
        <li class="breadcrumb-item"><a href="{{ path('social_network_template_variants', {'templateId': template.id}) }}">{{ template.name }}</a></li>
        <li class="breadcrumb-item active">{{ block('title') }}</li>
    </ol>
{% endblock %}

{% block content %}
    <style>
        {% for font in fonts %}
            {% for font_face in font.faces %}
                @font-face {
                    font-family: '{{ font.name }} ({{ font_face.name }})';
                    src: url('{{ uploaded_asset(font_face.filePath) }}');
                }
            {% endfor %}
        {% endfor %}
    </style>

    <div
        id="canvas-container"
        data-controller="canvas-editor canvas-history canvas-clipboard canvas-zoom canvas-text-toolbar canvas-input-properties canvas-image-properties canvas-alignment"
        data-canvas-editor-background-image-value="{{ uploaded_asset(variant.backgroundImage) }}"
        data-canvas-editor-custom-fonts-value='{{ font_faces|json_encode }}'
        data-canvas-editor-canvas-json="{{ variant.canvas }}"
        data-canvas-editor-edit-variant-url-value="{{ path('edit_social_network_template_variant', {'variantId': variant.id}) }}"
        data-canvas-history-canvas-editor-outlet="#canvas-container"
        data-canvas-clipboard-canvas-editor-outlet="#canvas-container"
        data-canvas-text-toolbar-canvas-editor-outlet="#canvas-container"
        data-canvas-input-properties-canvas-editor-outlet="#canvas-container"
        data-canvas-image-properties-canvas-editor-outlet="#canvas-container"
        data-canvas-alignment-canvas-editor-outlet="#canvas-container"
        data-action="
            canvas-editor:selection:changed->canvas-clipboard#onSelectionChanged
            canvas-editor:selection:changed->canvas-text-toolbar#updateFromSelection
            canvas-editor:selection:changed->canvas-input-properties#updateFromSelection
            canvas-editor:selection:changed->canvas-image-properties#updateFromSelection
            canvas-editor:selection:changed->canvas-alignment#onSelectionChanged
            canvas-editor:copy->canvas-clipboard#copy
            canvas-editor:paste->canvas-clipboard#paste
            asset-selected@window->canvas-editor#onAssetSelected
        "
    >
        {{ form_start(editor_form) }}

        <div class="card mb-2" style="position: sticky;top: 0px;z-index: 1000;">
            <div class="card-body p-2">
                <div class="mb-1">
                    <button class="btn btn-sm btn-outline-secondary me-3" data-action="canvas-editor#showBackgroundModal" type="button"><i class="mdi mdi-image"></i> Pozadí</button>

                    <button class="btn btn-sm btn-outline-secondary me-1 disabled" type="button" data-canvas-history-target="undoButton" data-action="canvas-history#undo"><i class="mdi mdi-undo-variant"></i></button>
                    <button class="btn btn-sm btn-outline-secondary me-3 disabled" type="button" data-canvas-history-target="redoButton" data-action="canvas-history#redo"><i class="mdi mdi-redo-variant"></i></button>

                    <button class="btn btn-sm btn-outline-secondary me-3 disabled" type="button" data-canvas-clipboard-target="duplicateButton" data-action="canvas-clipboard#duplicate"><i class="mdi mdi-content-copy"></i></button>

                    <button class="btn btn-sm btn-outline-secondary me-1 disabled" type="button" data-action="canvas-zoom#zoomOut" data-canvas-zoom-target="zoomOutButton"><i class="ri-zoom-out-line"></i></button>
                    <button class="btn btn-sm btn-outline-secondary me-1 disabled" type="button" data-action="canvas-zoom#zoomIn" data-canvas-zoom-target="zoomInButton"><i class="ri-zoom-in-line"></i></button>

                    <p class="d-inline-block my-0 small text-muted" data-canvas-zoom-target="scaleDisplay">100%</p>

                    <div class="d-inline-block float-end">
                        <p data-canvas-editor-target="unsavedChangesMessage" class="d-inline-block d-none my-0 me-2 small fw-bold text-danger">Neuložené změny</p>

                        <button class="btn btn-sm btn-primary me-1" type="button" data-action="canvas-editor#submitForm">Uložit</button>

                        <a href="{{ path('social_network_template_variant_export', {'variantId': variant.id}) }}" class="btn btn-sm btn-outline-secondary me-1" data-action="canvas-editor#confirmExport">Export</a>
                    </div>
                </div>

                <div>
                    <!-- Horizontal Alignment -->
                    <button type="button" class="btn btn-sm btn-outline-secondary disabled me-1" data-canvas-alignment-target="alignLeftButton" data-action="canvas-alignment#alignLeft"><i class="mdi mdi-format-horizontal-align-left"></i></button>
                    <button type="button" class="btn btn-sm btn-outline-secondary disabled me-1" data-canvas-alignment-target="alignCenterButton" data-action="canvas-alignment#alignCenter"><i class="mdi mdi-format-horizontal-align-center"></i></button>
                    <button type="button" class="btn btn-sm btn-outline-secondary disabled me-3" data-canvas-alignment-target="alignRightButton" data-action="canvas-alignment#alignRight"><i class="mdi mdi-format-horizontal-align-right"></i></button>

                    <!-- Vertical Alignment -->
                    <button type="button" class="btn btn-sm btn-outline-secondary disabled me-1" data-canvas-alignment-target="alignTopButton" data-action="canvas-alignment#alignTop"><i class="mdi mdi-format-vertical-align-top"></i></button>
                    <button type="button" class="btn btn-sm btn-outline-secondary disabled me-1" data-canvas-alignment-target="alignMiddleButton" data-action="canvas-alignment#alignMiddle"><i class="mdi mdi-format-vertical-align-center"></i></button>
                    <button type="button" class="btn btn-sm btn-outline-secondary disabled me-3" data-canvas-alignment-target="alignBottomButton" data-action="canvas-alignment#alignBottom"><i class="mdi mdi-format-vertical-align-bottom"></i></button>

                    <button class="btn btn-sm btn-outline-secondary me-1 disabled" type="button" data-canvas-alignment-target="bringToFrontButton" data-action="canvas-alignment#bringToFront"><i class="mdi mdi-arrange-bring-forward"></i></button>
                    <button class="btn btn-sm btn-outline-secondary me-3 disabled" type="button" data-canvas-alignment-target="sendToBackButton" data-action="canvas-alignment#sendToBack"><i class="mdi mdi-arrange-send-backward"></i></button>

                    <button class="btn btn-sm btn-outline-secondary me-3 disabled" type="button" data-canvas-alignment-target="deleteObjectButton" data-action="canvas-alignment#deleteObject"><i class="mdi mdi-delete"></i></button>
                </div>

            </div>
        </div>

        <div class="row">
            <div class="col-2">
                <div class="card" style="position: sticky;top: 93px;z-index: 999;">
                    <div class="card-body">
                        {% if fonts|length == 0 %}
                            <p class="text-danger">
                                <i class="text-danger uil-exclamation-triangle me-1"></i> Nejsou nahrány fonty
                            </p>
                        {% else %}
                            <button class="btn btn-sm btn-outline-secondary me-1 mb-1" type="button" data-action="canvas-editor#showAddTextModal"><i class="uil-text-fields"></i> Přidat text</button>
                        {% endif %}

                        <button class="btn btn-sm btn-outline-secondary me-1 mb-1" type="button" data-action="canvas-editor#showAddImageModal"><i class="uil-image"></i> Přidat obrázek</button>


                        <div id="font-controls" class="mt-1" style="display: none;" data-canvas-text-toolbar-target="panel">
                            <!-- Locked Control -->
                            <div class="mb-2 form-check">
                                <input type="checkbox" id="locked-control" class="form-check-input" data-canvas-input-properties-target="locked" data-action="change->canvas-input-properties#updateLocked">
                                <label for="locked-control" class="form-check-label small">Uzamčeno</label>
                            </div>

                            <!-- Hidable Control -->
                            <div class="mb-2 form-check">
                                <input type="checkbox" id="hidable-control" class="form-check-input" data-canvas-input-properties-target="hidable" data-action="change->canvas-input-properties#updateHidable">
                                <label for="hidable-control" class="form-check-label small">Schovatelnost</label>
                            </div>

                            <!-- Font Family Control -->
                            <div class="mb-2">
                                <label for="font-family-control" class="form-label small">Font Family:</label>
                                <select id="font-family-control" class="form-select form-select-sm" data-canvas-text-toolbar-target="fontFamily" data-action="change->canvas-text-toolbar#updateFontFamily">
                                    <!-- Options will be populated dynamically by Stimulus -->
                                </select>
                            </div>

                            <!-- Font Size Control -->
                            <div class="mb-2">
                                <label for="font-size-control" class="form-label small">Font Size:</label>
                                <input type="number" id="font-size-control" class="form-control form-control-sm" data-canvas-text-toolbar-target="fontSize" data-action="input->canvas-text-toolbar#updateFontSize">
                            </div>

                            <!-- Font Color Control -->
                            <div class="mb-2">
                                <label for="font-color-control" class="form-label small">Font Color (Hex):</label>
                                <input type="text" id="font-color-control" class="form-control form-control-sm" data-canvas-text-toolbar-target="fontColor" data-action="input->canvas-text-toolbar#updateFontColor">
                            </div>

                            <!-- Text Align Control -->
                            <div class="mb-2">
                                <label for="text-align-control" class="form-label small">Text Align:</label>
                                <select id="text-align-control" class="form-select form-select-sm" data-canvas-text-toolbar-target="textAlign" data-action="change->canvas-text-toolbar#updateTextAlign">
                                    <option value="left">Left</option>
                                    <option value="center">Center</option>
                                    <option value="right">Right</option>
                                    <option value="justify">Justify</option>
                                </select>
                            </div>

                            <!-- Text Decoration Control -->
                            <div class="mb-2">
                                <label for="text-decoration-control" class="form-label small">Text Decoration:</label>
                                <select id="text-decoration-control" class="form-select form-select-sm" data-canvas-text-toolbar-target="textDecoration" data-action="change->canvas-text-toolbar#updateTextDecoration">
                                    <option value="none">None</option>
                                    <option value="underline">Underline</option>
                                    <option value="line-through">Line Through</option>
                                    <option value="overline">Overline</option>
                                </select>
                            </div>

                            <!-- Max Length Control -->
                            <div class="mb-2">
                                <label for="max-length-control" class="form-label small">Max Length:</label>
                                <input type="number" id="max-length-control" class="form-control form-control-sm" data-canvas-text-toolbar-target="maxLength" data-action="blur->canvas-text-toolbar#updateMaxLength">
                            </div>

                            <!-- Name Control -->
                            <div class="mb-2">
                                <label for="name-control" class="form-label small">Název:</label>
                                <input type="text" id="name-control" class="form-control form-control-sm" data-canvas-input-properties-target="name" data-action="blur->canvas-input-properties#updateName">
                            </div>

                            <!-- Name Control -->
                            <div class="mb-2">
                                <label for="description-control" class="form-label small">Nápověda:</label>
                                <input type="text" id="description-control" class="form-control form-control-sm" data-canvas-input-properties-target="description" data-action="blur->canvas-input-properties#updateDescription">
                            </div>

                            <!-- Uppercase Control -->
                            <div class="mb-2 form-check">
                                <input type="checkbox" id="uppercase-control" class="form-check-input" data-canvas-input-properties-target="uppercase" data-action="change->canvas-input-properties#updateUppercase">
                                <label for="uppercase-control" class="form-check-label small">Verzálky</label>
                            </div>
                        </div>

                        <div id="image-controls" class="mt-1" style="display: none;" data-canvas-image-properties-target="panel">
                            <hr class="my-2">
                            <p class="small fw-bold mb-1"><i class="uil-image"></i> Obrázek</p>

                            <div class="mb-2 form-check">
                                <input type="checkbox" id="image-placeholder-control" class="form-check-input" data-canvas-image-properties-target="placeholder" data-action="change->canvas-image-properties#updatePlaceholder">
                                <label for="image-placeholder-control" class="form-check-label small">Placeholder (uživatel vyplní obrázek)</label>
                            </div>

                            <div data-canvas-image-properties-target="details" style="display: none;">
                                <div class="mb-2">
                                    <label for="image-name-control" class="form-label small">Název:</label>
                                    <input type="text" id="image-name-control" class="form-control form-control-sm" data-canvas-image-properties-target="name" data-action="blur->canvas-image-properties#updateName">
                                </div>

                                <div class="mb-2">
                                    <label for="image-description-control" class="form-label small">Nápověda:</label>
                                    <input type="text" id="image-description-control" class="form-control form-control-sm" data-canvas-image-properties-target="description" data-action="blur->canvas-image-properties#updateDescription">
                                </div>

                                <div class="mb-2 form-check">
                                    <input type="checkbox" id="image-allow-move-control" class="form-check-input" data-canvas-image-properties-target="allowMove" data-action="change->canvas-image-properties#updateAllowMove">
                                    <label for="image-allow-move-control" class="form-check-label small">Povolit posun</label>
                                </div>
                                <div class="mb-2 form-check">
                                    <input type="checkbox" id="image-allow-resize-control" class="form-check-input" data-canvas-image-properties-target="allowResize" data-action="change->canvas-image-properties#updateAllowResize">
                                    <label for="image-allow-resize-control" class="form-check-label small">Povolit změnu velikosti</label>
                                </div>
                                <div class="mb-2 form-check">
                                    <input type="checkbox" id="image-allow-rotate-control" class="form-check-input" data-canvas-image-properties-target="allowRotate" data-action="change->canvas-image-properties#updateAllowRotate">
                                    <label for="image-allow-rotate-control" class="form-check-label small">Povolit rotaci</label>
                                </div>
                                <div class="mb-2 form-check">
                                    <input type="checkbox" id="image-hidable-control" class="form-check-input" data-canvas-image-properties-target="hidable" data-action="change->canvas-image-properties#updateHidable">
                                    <label for="image-hidable-control" class="form-check-label small">Schovatelnost</label>
                                </div>

                                <label class="form-label small mb-1">Složky galerie pro uživatele:</label>
                                {% for dir in gallery_directories %}
                                    <div class="form-check">
                                        <input type="checkbox" class="form-check-input" id="image-dir-{{ dir.id }}" data-canvas-image-properties-target="directory" data-directory-id="{{ dir.id }}" data-action="change->canvas-image-properties#updateDirectories">
                                        <label class="form-check-label small" for="image-dir-{{ dir.id }}">{{ dir.name }}</label>
                                    </div>
                                {% endfor %}

                                {# Live guidance: empty allow-list = "offer all folders"; no folders at all = dead end. #}
                                <div class="alert alert-warning py-1 px-2 small mt-1 mb-0" role="alert" data-canvas-image-properties-target="warning" style="display: none;"></div>
                            </div>
                        </div>

                    </div>
                </div>
            </div>

            <div class="col-10">
                <div class="canvas-wrapper" data-canvas-zoom-target="canvasContainer">
                    <canvas id="c" width="{{ variant.dimension.width }}" height="{{ variant.dimension.height }}"></canvas>
                </div>

                {{ form_widget(editor_form.canvas, { attr: { 'data-canvas-editor-target': 'canvas' } }) }}
                {{ form_widget(editor_form.textInputs, { attr: { 'data-canvas-editor-target': 'textInputs' } }) }}
                {{ form_widget(editor_form.imageInputs, { attr: { 'data-canvas-editor-target': 'imageInputs' } }) }}
                {{ form_widget(editor_form.imagePreview, { attr: { 'data-canvas-editor-target': 'previewImage' } }) }}
            </div>
        </div>

        {{ form_end(editor_form) }}

        {#
            Stage 7: unified project image gallery modal. Replaces the two
            ad-hoc upload modals (background + addImage). The canvas-editor
            orchestrator decides which canvas operation to run when the user
            picks an asset, based on the mode it sets before opening this
            modal.
        #}
        <div class="modal fade" id="imageGalleryModal" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog modal-lg">
                <div class="modal-content">
                    <twig:Project:ImageGallery :project="project" />
                </div>
            </div>
        </div>

        <!-- Add text modal -->
        <div class="modal fade" id="addTextModal" tabindex="-1" aria-labelledby="addTextModalLabel" aria-hidden="true">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title" id="addTextModalLabel">Přidat text</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <form id="addTextForm" data-action="submit->canvas-editor#submitAddText">
                            <div class="mb-3">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" id="lockedCheckbox">
                                    <label class="form-check-label" for="lockedCheckbox">Zamknout editaci textu</label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" id="hidableCheckbox">
                                    <label class="form-check-label" for="hidableCheckbox">Povolit schovávatelnost</label>
                                </div>
                            </div>
                            <div class="mb-3">
                                <label for="textName" class="form-label">Název textového pole</label>
                                <input type="text" class="form-control" id="textName">
                            </div>
                            <div class="mb-3">
                                <label for="description" class="form-label">Popis</label>
                                <textarea type="text" class="form-control" id="description"></textarea>
                            </div>
                            <div class="mb-3">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" id="uppercaseCheckbox">
                                    <label class="form-check-label" for="uppercaseCheckbox">Verzálky</label>
                                </div>
                            </div>
                        </form>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Zrušit</button>
                        <button type="button" class="btn btn-primary" data-action="canvas-editor#submitAddText">Přidat text</button>
                    </div>
                </div>
            </div>
        </div>

        {# Shown when Export is clicked with unsaved canvas changes. The export
           renders from the last saved variant, so we let the user save first. #}
        <div class="modal fade" id="exportUnsavedModal" tabindex="-1" aria-labelledby="exportUnsavedModalLabel" aria-hidden="true">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title" id="exportUnsavedModalLabel">Neuložené změny</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <p class="mb-0">Máte neuložené změny. Export se vytvoří z naposledy uložené verze, takže vaše poslední úpravy se v něm neprojeví. Chcete změny nejdříve uložit?</p>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Zrušit</button>
                        <button type="button" class="btn btn-outline-danger" data-action="canvas-editor#exportWithoutSaving">Pokračovat bez uložení</button>
                        <button type="button" class="btn btn-primary" data-action="canvas-editor#saveAndExport">Uložit a exportovat</button>
                    </div>
                </div>
            </div>
        </div>

    </div>
{% endblock %}
