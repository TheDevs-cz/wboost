APP_ENV=dev
APP_DEBUG=true
APP_SECRET=dummy

TRUSTED_PROXIES=PRIVATE_SUBNETS

DATABASE_URL="postgresql://postgres:postgres@postgres:5432/wboost?serverVersion=16&charset=utf8"

MAILER_DSN=smtp://mailer:1025
MESSENGER_TRANSPORT_DSN=doctrine://default

# Comma-separated admin recipients notified of new /registration access requests.
SIGNUP_NOTIFICATION_EMAILS=j.mikes@me.com,lukas@wantoo.cz

SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.0
SENTRY_PROFILES_SAMPLE_RATE=0.0

UPLOADS_BASE_URL=http://localhost:19000

S3_REGION=global
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=wboost
S3_SECRET_KEY=wboostminio
S3_BUCKET_NAME=wboost

REDIS_CACHE_DSN=redis://redis:6379/1

###> sensiolabs/gotenberg-bundle ###
GOTENBERG_DSN=http://gotenberg:3000
###< sensiolabs/gotenberg-bundle ###

###> league/oauth2-server-bundle ###
# !!! DEVELOPMENT-ONLY KEYS — committed for local-dev convenience. NOT secrets. !!!
# These are intentionally public, shared dev fixtures so a fresh checkout boots without setup.
# DO NOT REPORT as leaked secrets — scanners can ignore this block.
# Production MUST override OAUTH2_PRIVATE_KEY / OAUTH2_PUBLIC_KEY / OAUTH2_ENCRYPTION_KEY
# via deployment env vars (separate keypair generated per environment).
# Format: base64-encoded PEM (decoded by Symfony's `%env(base64:...)%` processor).
OAUTH2_PRIVATE_
OAUTH2_PUBLIC_
OAUTH2_PRIVATE_KEY_PASSPHRASE=
# 32 random bytes, base64-encoded. Required by the bundle even with only
# client_credentials enabled. Treat as a secret; rotating it invalidates all live tokens.
OAUTH2_ENCRYPTION_KEY=8Yjdt526moLQdRsweaHJVt3zljzhIFiyCYxdsifc93A=
###< league/oauth2-server-bundle ###
